---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PolicyArticle from '../../components/PolicyArticle.astro';
import { formatDate } from '../../lib/format';
import { withBase } from '../../lib/url';

const entries = await getCollection('policies');
const globalEntry = entries.find((e) => e.data.productId === 'global');
const perProduct = entries
  .filter((e) => e.data.productId !== 'global')
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

if (!globalEntry) {
  throw new Error('A global privacy policy (productId: global) is required.');
}
const { Content } = await render(globalEntry);
---

<BaseLayout
  title="Website Privacy Policy"
  description="Privacy policy for the MetKap Studio website (metkapstudio.com). Apps and games each have their own policy, listed here."
>
  <PolicyArticle policy={globalEntry.data}>
    <Content />
  </PolicyArticle>

  <section class="band band-tail per-product" aria-labelledby="per-product-h">
    <h2 id="per-product-h" class="band-title">App &amp; game privacy policies</h2>
    <p class="per-product-lead measure">
      These are separate from the website policy above. Some apps collect data
      the website doesn&rsquo;t — open a policy for the details.
    </p>
    <ul class="policy-list" role="list">
      {
        perProduct.map((e) => (
          <li class="reveal">
            <a class="policy-link" href={withBase(`/privacy/${e.data.productId}/`)}>
              <span class="policy-name">{e.data.title}</span>
              <span class="policy-date">
                updated {formatDate(e.data.lastUpdated)}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

<style>
  .per-product {
    margin-top: var(--band-y);
  }
  .per-product-lead {
    margin: 0 0 var(--space-6);
    color: var(--muted);
  }
  /* Card grid, matching the policy sections above and the rest of the site,
     rather than a hairline-divided list in a narrow column. */
  .policy-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-4);
    grid-template-columns: repeat(auto-fit, minmax(min(20rem, 100%), 1fr));
  }
  .policy-link {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
    align-items: baseline;
    justify-content: space-between;
    padding: var(--space-5);
    border-radius: var(--radius);
    background: linear-gradient(180deg, var(--surface), var(--surface-2));
    color: var(--text);
    transition: background-color var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .policy-link:hover {
    color: var(--text-strong);
    transform: translateY(-2px);
  }
  .policy-name {
    font-weight: 650;
    letter-spacing: -0.01em;
  }
  .policy-date {
    font-family: var(--font-mono);
    color: var(--faint);
    font-size: var(--text-xs);
    white-space: nowrap;
  }
</style>
