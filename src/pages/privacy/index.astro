---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PolicyArticle from '../../components/PolicyArticle.astro';
import { formatDate } from '../../lib/format';
import { withBase } from '../../lib/url';

const entries = await getCollection('policies');
const globalEntry = entries.find((e) => e.data.productId === 'global');
const perProduct = entries
  .filter((e) => e.data.productId !== 'global')
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

if (!globalEntry) {
  throw new Error('A global privacy policy (productId: global) is required.');
}
const { Content } = await render(globalEntry);
---

<BaseLayout
  title="Website Privacy Policy"
  description="Privacy policy for the MetKap Studio website (metkapstudio.com). Apps and games each have their own policy, listed here."
>
  <PolicyArticle policy={globalEntry.data}>
    <Content />
  </PolicyArticle>

  <section class="per-product reveal" aria-labelledby="per-product-h">
    <h2 id="per-product-h">App &amp; game privacy policies</h2>
    <p class="per-product-lead">
      These are separate from the website policy above. Some apps collect data
      the website doesn't — open a policy for the details.
    </p>
    <ul class="policy-list" role="list">
      {
        perProduct.map((e) => (
          <li>
            <a href={withBase(`/privacy/${e.data.productId}/`)}>{e.data.title}</a>
            <span class="policy-date">
              updated {formatDate(e.data.lastUpdated)}
            </span>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

<style>
  .per-product {
    max-width: var(--maxw-prose);
    margin-inline: auto;
    margin-top: var(--space-12);
    border-top: 1px solid var(--border);
    padding-top: var(--space-8);
  }
  .per-product h2 {
    margin: 0 0 var(--space-2);
    font-size: var(--text-xl);
  }
  .per-product-lead {
    margin: 0 0 var(--space-5);
    color: var(--muted);
  }
  .policy-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .policy-list li {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: baseline;
    justify-content: space-between;
    padding-block: var(--space-3);
    border-bottom: 1px solid var(--border);
  }
  .policy-date {
    color: var(--muted);
    font-size: 0.875rem;
  }
</style>
