---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PolicyArticle from '../../components/PolicyArticle.astro';

export async function getStaticPaths() {
  const entries = await getCollection('policies');
  return entries
    .filter((e) => e.data.productId !== 'global')
    .map((entry) => ({
      params: { slug: entry.data.productId },
      props: { entry },
    }));
}

interface Props {
  entry: CollectionEntry<'policies'>;
}
const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={`Privacy policy — ${entry.data.title}.`}>
  <p class="back"><a href="/privacy/">← All privacy policies</a></p>
  <PolicyArticle policy={entry.data}>
    <Content />
  </PolicyArticle>
</BaseLayout>

<style>
  .back {
    max-width: 44rem;
    margin: 0;
    padding-top: var(--space-8);
  }
  .back a {
    font-size: 0.9375rem;
  }
</style>
