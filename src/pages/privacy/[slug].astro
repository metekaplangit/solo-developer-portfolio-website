---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PolicyArticle from '../../components/PolicyArticle.astro';
import { withBase } from '../../lib/url';

export async function getStaticPaths() {
  const entries = await getCollection('policies');
  return entries
    .filter((e) => e.data.productId !== 'global')
    .map((entry) => ({
      params: { slug: entry.data.productId },
      props: { entry },
    }));
}

interface Props {
  entry: CollectionEntry<'policies'>;
}
const { entry } = Astro.props;
const { Content } = await render(entry);

// The product this policy belongs to supplies the app icon (and its detail link).
const products = await getCollection('products');
const product = products.find((p) => p.data.id === entry.data.productId);
const icon = product?.data.icon ?? null;
const iconHref = product ? `/apps/${product.data.slug}/` : undefined;
---

<BaseLayout title={entry.data.title} description={`Privacy policy — ${entry.data.title}.`}>
  <p class="back"><a href={withBase('/privacy/')}>← All privacy policies</a></p>
  <PolicyArticle policy={entry.data} icon={icon} iconHref={iconHref} iconName={product?.data.name}>
    <Content />
  </PolicyArticle>
</BaseLayout>

<style>
  .back {
    max-width: var(--maxw-prose);
    margin-inline: auto;
    padding-top: var(--space-8);
  }
  .back a {
    font-size: 0.9375rem;
  }
</style>
