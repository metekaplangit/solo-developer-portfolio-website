---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { site } from '../../lib/site';
import { withBase } from '../../lib/url';

const values = [
  'Privacy first — collect as little as possible, and say so plainly.',
  'Offline-friendly and fast wherever it makes sense.',
  'No dark patterns, ads, or tracking.',
];
---

<BaseLayout
  title="About"
  description="About MetKap Studio and the developer behind these apps and games."
>
  <PageHeader title="About">
    <p>{site.tagline}</p>
  </PageHeader>

  <div class="about">
    <p class="intro">
      MetKap Studio is the one-person studio of {site.person}. I build small,
      focused apps and games and try to keep them calm, fast, and respectful of
      your attention and your data.
    </p>

    <section class="reveal" aria-labelledby="values-h">
      <h2 id="values-h">How I build</h2>
      <ul class="values" role="list">
        {values.map((v) => <li>{v}</li>)}
      </ul>
    </section>

    <section class="reveal" aria-labelledby="links-h">
      <h2 id="links-h">Elsewhere</h2>
      <ul class="links" role="list">
        <li><a href={withBase('/apps/')}>Apps &amp; Games</a></li>
        <li><a href={withBase('/support/')}>Support</a> ({site.supportEmail})</li>
        {
          site.social.map((s) => (
            <li>
              <a href={s.url} rel="me noopener" target="_blank">
                {s.label}
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  .about {
    max-width: var(--maxw-prose);
    margin-inline: auto;
  }
  .intro {
    font-size: var(--text-lg);
    color: var(--text);
    margin: 0 0 var(--space-12);
    line-height: 1.6;
  }
  .about h2 {
    font-size: var(--text-xl);
    margin: 0 0 var(--space-4);
  }
  .about section {
    margin-bottom: var(--space-10);
  }
  .values {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-3);
  }
  .values li {
    position: relative;
    padding: var(--space-4) var(--space-5) var(--space-4) var(--space-8);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    color: var(--muted);
  }
  .values li::before {
    content: '';
    position: absolute;
    left: var(--space-4);
    top: 1.35em;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
  }
  .links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-2);
  }
</style>
