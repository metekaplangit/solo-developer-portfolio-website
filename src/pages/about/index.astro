---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../lib/site';
---

<BaseLayout
  title="About"
  description="About the solo developer behind these apps and games."
>
  <div class="about">
    <h1>About</h1>
    <p class="lede">{site.tagline}</p>

    <p>
      I'm {site.name}, an independent developer. I build small, focused apps and
      games and try to keep them calm, fast, and respectful of your attention
      and your data.
    </p>

    <section aria-labelledby="values-h">
      <h2 id="values-h">How I build</h2>
      <ul>
        <li>Privacy first — collect as little as possible, say so plainly.</li>
        <li>Offline-friendly and fast wherever it makes sense.</li>
        <li>No dark patterns, ads, or tracking.</li>
      </ul>
    </section>

    <section aria-labelledby="links-h">
      <h2 id="links-h">Elsewhere</h2>
      <ul>
        <li><a href="/apps/">Apps &amp; Games</a></li>
        <li><a href="/support/">Support</a> ({site.supportEmail})</li>
        {
          site.social.map((s) => (
            <li>
              <a href={s.url} rel="me noopener" target="_blank">
                {s.label}
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  .about {
    max-width: 42rem;
    padding-block: var(--space-12) var(--space-8);
  }
  .about h1 {
    margin: 0 0 var(--space-3);
  }
  .lede {
    margin: 0 0 var(--space-6);
    color: var(--color-muted);
    font-size: 1.125rem;
  }
</style>
