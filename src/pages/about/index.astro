---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../lib/site';
import { withBase } from '../../lib/url';

/* Values — a presentational rewrap of the three commitments this page has
   always carried, plus the support promise that already ships site-wide in the
   trust line. Every claim below is restated from somewhere it is already
   published (privacy pages, support page, product content); none is new. */
const values = [
  {
    title: 'Privacy first',
    body:
      'Collect as little as possible, and say so plainly. Every product has its own privacy page in language you can actually read.',
  },
  {
    title: 'Offline and fast',
    body:
      'Offline-friendly and quick wherever it makes sense. Software should not need a network round-trip to show you a timer.',
  },
  {
    title: 'No dark patterns',
    body:
      'No ads, no tracking, no engagement traps. Nothing on screen is trying to talk you into anything.',
  },
  {
    title: 'A real person answers',
    body:
      'Support goes straight to me. If something breaks you hear back — usually within 2–3 business days.',
  },
];
---

<BaseLayout
  title="About"
  description="About MetKap Studio and the developer behind these apps and games."
>
  <section class="band band-lead about-hero" aria-labelledby="about-h">
    <p class="eyebrow">About the studio</p>
    <h1 id="about-h" class="about-title">One person, making software that behaves.</h1>
    <p class="lede measure">
      MetKap Studio is the one-person studio of {site.person}. I build small,
      focused apps and games and try to keep them calm, fast, and respectful of
      your attention and your data.
    </p>
  </section>

  <section class="band band-loose values-band" aria-labelledby="values-h">
    <h2 id="values-h" class="band-title">How I build</h2>
    <ul class="values card-grid" role="list">
      {
        values.map((v) => (
          <li class="card reveal">
            <h3 class="card-title">{v.title}</h3>
            <p>{v.body}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="band band-loose band-tail contact-band" aria-labelledby="contact-h">
    <div class="panel panel-accent contact reveal">
      <div class="contact-copy">
        <h2 id="contact-h" class="contact-title">Get in touch</h2>
        <p>Questions, bugs, or ideas — the door&rsquo;s open.</p>
      </div>
      <div class="contact-actions">
        <a class="btn btn-primary" href={withBase('/support/')}>Contact support</a>
        {
          site.social.map((s) => (
            <a class="btn btn-secondary" href={s.url} rel="me noopener" target="_blank">
              {s.label}
            </a>
          ))
        }
      </div>
    </div>

    <ul class="elsewhere" role="list">
      <li><a href={`mailto:${site.supportEmail}`}>{site.supportEmail}</a></li>
      <li><a href={withBase('/apps/')}>Apps &amp; Games</a></li>
      <li><a href={withBase('/privacy/')}>Privacy</a></li>
    </ul>
  </section>
</BaseLayout>

<style>
  .about-title {
    margin: var(--space-4) 0 var(--space-6);
    font-size: var(--text-3xl);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.03em;
    /* 16ch left 690px (60%) of the rail dead at 44px type. `text-wrap: balance`
       is already global and does the line-breaking work. */
    max-width: 22ch;
  }
  .lede {
    margin: 0;
    color: var(--muted);
    font-size: var(--text-lg);
    line-height: 1.6;
  }

  /* Four values, two-up. Only the track floor is local — padding, radius,
     title and body all come from the shared `.card` system so this grid can
     never drift from the ones on Support, the product page and the policies
     again. */
  .values {
    grid-template-columns: repeat(auto-fit, minmax(min(26rem, 100%), 1fr));
    gap: var(--space-5);
  }

  .contact {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }
  .contact-title {
    margin: 0 0 var(--space-2);
    font-size: var(--text-xl);
    letter-spacing: -0.02em;
  }
  .contact-copy p {
    margin: 0;
    color: var(--muted);
  }
  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .elsewhere {
    list-style: none;
    margin: var(--space-8) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-6);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--faint);
  }
  .elsewhere a {
    color: var(--muted);
  }
  .elsewhere a:hover {
    color: var(--text-strong);
  }
</style>
