---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import ProductAvatar from '../components/ProductAvatar.astro';
import Badge from '../components/Badge.astro';
import { site } from '../lib/site';
import { withBase } from '../lib/url';
import { getFeatured, sortProducts, statusLabel } from '../lib/products';
import { canonicalPrivacyUrl } from '../lib/privacy';

const entries = await getCollection('products');
const products = entries.map((e) => e.data);
const featured = getFeatured(products);
const showcase = featured.length > 0 ? featured : sortProducts(products).slice(0, 3);
const shippedCount = products.filter((p) => p.status === 'released').length;

// The lead product gets a spotlight panel; any others fall to the card grid.
const spotlight = showcase[0];
const rest = showcase.slice(1);
---

<BaseLayout title={site.name} description={site.description}>
  <section class="hero">
    <p class="eyebrow">{site.tagline}</p>
    <h1 class="hero-title">{site.name}</h1>
    <p class="lede">{site.description}</p>
    <div class="hero-cta">
      <a class="btn btn-primary" href={withBase('/apps/')}>See apps &amp; games</a>
      <a class="btn btn-secondary" href={withBase('/support/')}>Get support</a>
    </div>
    <p class="hero-meta">
      {shippedCount > 0 ? `${shippedCount} shipped · ` : ''}Privacy &amp; support
      for every product
    </p>
  </section>

  <section class="featured" aria-labelledby="featured-h">
    <div class="section-head">
      <h2 id="featured-h">Featured</h2>
      <a class="section-link" href={withBase('/apps/')}>All apps &amp; games →</a>
    </div>

    {
      spotlight && (
        <article class="spotlight reveal">
          <div class="spotlight-media">
            <ProductAvatar icon={spotlight.icon} name={spotlight.name} size={112} />
          </div>
          <div class="spotlight-body">
            <div class="spotlight-tags">
              <Badge label={spotlight.type === 'game' ? 'Game' : 'App'} tone="accent" />
              <Badge label={statusLabel(spotlight.status)} />
            </div>
            <h3 class="spotlight-name">
              <a href={withBase(`/apps/${spotlight.slug}/`)}>{spotlight.name}</a>
            </h3>
            <p class="spotlight-lede">{spotlight.summary}</p>
            {spotlight.features.length > 0 && (
              <ul class="spotlight-highlights" role="list">
                {spotlight.features.slice(0, 3).map((f) => (
                  <li>{f}</li>
                ))}
              </ul>
            )}
            <div class="spotlight-cta">
              <a class="btn btn-primary" href={withBase(`/apps/${spotlight.slug}/`)}>
                View {spotlight.name}
              </a>
              <a class="btn btn-secondary" href={withBase(canonicalPrivacyUrl(spotlight))}>
                Privacy
              </a>
            </div>
          </div>
        </article>
      )
    }

    {
      rest.length > 0 && (
        <ul class="grid" role="list">
          {rest.map((p) => (
            <li class="reveal">
              <ProductCard product={p} />
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: var(--space-24) var(--space-16);
    max-width: 46rem;
  }
  .hero-title {
    margin: var(--space-3) 0 var(--space-5);
    font-size: var(--display);
    font-weight: 700;
    letter-spacing: -0.03em;
  }
  .lede {
    margin: 0 0 var(--space-8);
    color: var(--muted);
    font-size: var(--text-xl);
    line-height: 1.5;
    max-width: 38rem;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: center;
  }
  .hero-meta {
    margin: var(--space-6) 0 0;
    color: var(--faint);
    font-size: var(--text-sm);
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }
  .section-head h2 {
    margin: 0;
    font-size: var(--text-2xl);
  }
  .section-link {
    font-size: var(--text-sm);
    color: var(--muted);
    white-space: nowrap;
  }
  .section-link:hover {
    color: var(--text-strong);
  }
  .grid {
    list-style: none;
    margin: var(--space-6) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-5);
    grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
  }

  /* Featured spotlight — a richer, product-led panel for the lead app. */
  .spotlight {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-8);
    align-items: center;
    padding: var(--space-8);
    border-radius: var(--radius-lg);
    background:
      radial-gradient(130% 150% at 0% 0%, var(--accent-soft), transparent 58%),
      linear-gradient(180deg, var(--surface), var(--surface-2));
    box-shadow: var(--shadow-md);
  }
  .spotlight-media {
    display: grid;
    place-items: center;
  }
  .spotlight-tags {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }
  .spotlight-name {
    margin: 0 0 var(--space-2);
    font-size: var(--text-2xl);
    letter-spacing: -0.02em;
  }
  .spotlight-name a {
    color: var(--text-strong);
    text-decoration: none;
  }
  .spotlight-name a:hover {
    text-decoration: underline;
    text-decoration-color: var(--accent);
  }
  .spotlight-lede {
    margin: 0;
    color: var(--muted);
    font-size: var(--text-lg);
    line-height: 1.5;
    max-width: 34rem;
  }
  .spotlight-highlights {
    list-style: none;
    margin: var(--space-5) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-2);
  }
  .spotlight-highlights li {
    position: relative;
    padding-left: var(--space-5);
    color: var(--muted);
    font-size: var(--text-sm);
  }
  .spotlight-highlights li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.62em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }
  .spotlight-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }
  @media (max-width: 40rem) {
    .spotlight {
      grid-template-columns: 1fr;
      gap: var(--space-6);
      padding: var(--space-6);
    }
    .spotlight-media {
      justify-items: start;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero > * {
      animation: rise 0.6s var(--ease) both;
    }
    .hero .hero-title { animation-delay: 0.05s; }
    .hero .lede { animation-delay: 0.1s; }
    .hero .hero-cta { animation-delay: 0.15s; }
    .hero .hero-meta { animation-delay: 0.2s; }
    @keyframes rise {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }
  }
</style>
