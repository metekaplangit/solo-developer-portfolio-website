---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import ProductAvatar from '../components/ProductAvatar.astro';
import Badge from '../components/Badge.astro';
import DownloadButton from '../components/DownloadButton.astro';
import FactsLine from '../components/FactsLine.astro';
import { site } from '../lib/site';
import { withBase } from '../lib/url';
import { getFeatured, sortProducts, statusLabel, visibleStoreLinks } from '../lib/products';
import { canonicalPrivacyUrl } from '../lib/privacy';
import { organizationSchema, websiteSchema } from '../lib/schema';
import { resolveScreenshot } from '../lib/screenshots';

const entries = await getCollection('products');
const products = entries.map((e) => e.data);
const featured = getFeatured(products);
const showcase = featured.length > 0 ? featured : sortProducts(products).slice(0, 3);

// The lead product gets a spotlight panel; any others fall to the card grid.
const spotlight = showcase[0];
const rest = showcase.slice(1);

// The spotlight leads with the product's first real screenshot when one exists,
// falling back to the icon avatar otherwise.
const leadShot = spotlight?.screenshots?.[0];
const leadImg = leadShot ? resolveScreenshot(leadShot.path) : undefined;

// Hero leads with the flagship's download button when it has one; otherwise
// "See apps & games" stays the primary action.
const heroHasDownload =
  spotlight != null && visibleStoreLinks(spotlight).some((l) => l.status === 'available');

/* "Featured" only means something when there is a set to be featured FROM.
   With a single product, the catalog scaffolding (a "Featured" kicker, an
   "All apps & games →" link, and a grid re-showing the same app with less
   information than the spotlight already gave) advertises the emptiness
   instead of the product — so the product simply becomes the page's second
   band under its own name. This re-arms itself the moment a second product
   exists; it is never a decision about what to *claim*, only what to *label*. */
const hasCatalog = products.length > 1;

// The home page's maker voice is the product's own note — the real, approved
// copy from the content file. Nothing here is written for the page.
const makerLines = spotlight?.makerNote ?? [];
---

<BaseLayout title={site.name} description={site.description} schema={[organizationSchema(), websiteSchema()]}>
  <section class="band band-lead hero" aria-labelledby="hero-h">
    <p class="eyebrow">{site.tagline}</p>
    <h1 id="hero-h" class="hero-title">{site.headline}</h1>
    <p class="lede measure">{site.lede}</p>
    <div class="hero-cta">
      {/* The hero button names the store rather than the action; every other
          download button on the site just says "Download". */}
      {heroHasDownload && <DownloadButton product={spotlight} label="Mac App Store" />}
      <a class={`btn ${heroHasDownload ? 'btn-secondary' : 'btn-primary'}`} href={withBase('/apps/')}>
        See apps &amp; games
      </a>
    </div>
    {heroHasDownload && <FactsLine product={spotlight} />}
  </section>

  {
    spotlight && (
      <section class="band featured" aria-labelledby="featured-h">
        {hasCatalog ? (
          <div class="band-head">
            <h2 id="featured-h" class="band-title">Featured</h2>
            <a class="section-link" href={withBase('/apps/')}>All apps &amp; games →</a>
          </div>
        ) : (
          <h2 id="featured-h" class="visually-hidden">{spotlight.name}</h2>
        )}

        <article class={`panel panel-accent spotlight reveal${leadImg ? ' has-shot' : ''}`}>
          <div class="spotlight-media">
            {leadImg ? (
              <a class="shot-frame" href={withBase(`/apps/${spotlight.slug}/`)} aria-label={`Open ${spotlight.name}`}>
                <Image
                  src={leadImg}
                  alt={leadShot.altText}
                  widths={[480, 720, 960, 1280]}
                  sizes="(min-width: 60rem) 38rem, calc(100vw - 6rem)"
                  format="webp"
                  quality={78}
                  loading="eager"
                />
              </a>
            ) : (
              <ProductAvatar icon={spotlight.icon} name={spotlight.name} size={112} href={`/apps/${spotlight.slug}/`} redundant />
            )}
          </div>
          <div class="spotlight-body">
            <div class="spotlight-tags">
              <Badge label={spotlight.type === 'game' ? 'Game' : 'App'} tone="accent" />
              <Badge label={statusLabel(spotlight.status)} />
            </div>
            <h3 class="spotlight-name">
              <a href={withBase(`/apps/${spotlight.slug}/`)}>{spotlight.name}</a>
            </h3>
            <p class="spotlight-lede">{spotlight.summary}</p>
            <div class="spotlight-cta">
              <a class="btn btn-primary" href={withBase(`/apps/${spotlight.slug}/`)}>
                View {spotlight.name}
              </a>
              <a class="btn btn-secondary" href={withBase(canonicalPrivacyUrl(spotlight))}>
                Privacy
              </a>
            </div>
          </div>
        </article>
      </section>
    )
  }

  {
    hasCatalog && rest.length > 0 && (
      <section class="band catalog" aria-labelledby="catalog-h">
        <h2 id="catalog-h" class="band-title">The catalog</h2>
        <ul class="grid" role="list">
          {rest.map((p) => (
            <li class="reveal">
              <ProductCard product={p} />
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    makerLines.length > 0 && (
      <section class="band band-tail maker" aria-labelledby="maker-h">
        <h2 id="maker-h" class="visually-hidden">A note from the maker</h2>
        <blockquote class="maker-quote reveal">
          {makerLines.map((line) => (
            <p>{line}</p>
          ))}
          <footer class="maker-sig">
            <a href={withBase('/about/')}>{site.person}</a>{' · '}maker of {site.name}{' · '}
            <a href={withBase('/support/')}>direct support</a>, usually replies in 2–3 business days
          </footer>
        </blockquote>
      </section>
    )
  }
</BaseLayout>

<style>
  /* Hero — shares the band gutter, so its left edge is the SAME rail as the
     nav brand, every heading below, and the footer. The old hero centred
     itself in a narrower column and sat ~150px inboard of everything else;
     the text is capped by `.measure` instead of by the container. */
  .hero {
    padding-bottom: var(--band-y);
  }
  .hero-title {
    margin: var(--space-4) 0 var(--space-6);
    font-size: var(--display);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.035em;
    max-width: 18ch;
  }
  .lede {
    margin: 0 0 var(--space-8);
    color: var(--muted);
    font-size: var(--text-lg);
    line-height: 1.6;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: center;
  }

  .section-link {
    font-size: var(--text-sm);
    color: var(--muted);
    white-space: nowrap;
  }
  .section-link:hover {
    color: var(--text-strong);
  }

  /* Featured spotlight — image-forward. The screenshot is the largest element
     in the band; the text column is short and capped. */
  .spotlight {
    display: grid;
    grid-template-columns: 1fr; /* mobile: stacked, media on top */
    gap: clamp(var(--space-6), 3vw, var(--space-10));
    align-items: center;
  }
  .spotlight-media {
    display: grid;
    place-items: center;
    min-width: 0;
  }
  .spotlight-tags {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }
  .spotlight-name {
    margin: 0 0 var(--space-4);
    font-size: var(--text-2xl);
    letter-spacing: -0.025em;
  }
  .spotlight-name a {
    color: var(--text-strong);
    text-decoration: none;
  }
  .spotlight-name a:hover {
    text-decoration: underline;
    text-decoration-color: var(--accent);
  }
  .spotlight-lede {
    margin: 0;
    color: var(--muted);
    font-size: var(--text-base);
    line-height: 1.6;
    max-width: 34rem;
  }
  .spotlight-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }
  @media (prefers-reduced-motion: no-preference) {
    .shot-frame {
      transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
    }
    .shot-frame:hover {
      transform: translateY(-3px);
    }
  }
  @media (min-width: 60rem) {
    /* Icon fallback: icon | body. */
    .spotlight {
      grid-template-columns: auto 1fr;
    }
    /* Screenshot lead: a compact text column and a dominant image
       (body | shot; DOM order is media-first, so place explicitly).
       minmax(0, …) so the text column can never let its content's min-content
       width dictate the track and starve the image (see FactsLine note). */
    .spotlight.has-shot {
      grid-template-columns: minmax(0, 0.85fr) 1.15fr;
    }
    .spotlight.has-shot .spotlight-body {
      grid-column: 1;
      grid-row: 1;
    }
    .spotlight.has-shot .spotlight-media {
      grid-column: 2;
      grid-row: 1;
    }
  }

  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-5);
    grid-template-columns: repeat(auto-fit, minmax(min(18rem, 100%), 1fr));
  }

  /* Maker note — the page's closing beat. A person's voice in the last
     position, where the peak-end rule says half the memory forms. */
  .maker-quote {
    margin: 0;
    max-width: var(--measure-mid);
  }
  .maker-quote p {
    margin: 0 0 var(--space-4);
    font-size: var(--text-xl);
    font-weight: 400;
    line-height: 1.5;
    color: var(--text);
    letter-spacing: -0.01em;
  }
  .maker-sig {
    margin-top: var(--space-6);
    color: var(--faint);
    font-size: var(--text-sm);
  }
  .maker-sig a {
    color: var(--muted);
  }
  .maker-sig a:hover {
    color: var(--text-strong);
  }

  /* Entrance motion — transform ONLY, never opacity.
     A keyframe that starts at `opacity: 0` gates the content on the animation
     actually running. Animations do not advance in a non-rendering context
     (headless Lighthouse, a background tab, a print/preview renderer), so the
     hero froze at opacity 0 and axe reported the primary CTA as a serious
     contrast failure — on the one check that is merge-critical here. Animating
     the transform keeps every element visible at all times and still reads as
     a rise. Do not reintroduce opacity into these keyframes. */
  @media (prefers-reduced-motion: no-preference) {
    .hero > * {
      animation: rise 0.6s var(--ease) both;
    }
    .hero .hero-title { animation-delay: 0.05s; }
    .hero .lede { animation-delay: 0.1s; }
    .hero .hero-cta { animation-delay: 0.15s; }
    @keyframes rise {
      from { transform: translateY(12px); }
      to { transform: translateY(0); }
    }
  }
</style>
