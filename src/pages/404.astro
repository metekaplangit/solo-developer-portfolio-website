---
import BaseLayout from '../layouts/BaseLayout.astro';
import { nav } from '../lib/site';
import { withBase } from '../lib/url';
---

<BaseLayout
  title="Page not found"
  description="That page doesn't exist. Here are the main sections of the site."
>
  <section class="band band-lead band-tail notfound">
    <p class="code">404</p>
    <h1 class="notfound-title">Page not found</h1>
    <p class="lede measure">
      The page you were looking for doesn't exist or may have moved.
    </p>
    <nav aria-label="Site sections">
      <ul class="links">
        {nav.map((item) => <li><a href={withBase(item.href)}>{item.label}</a></li>)}
      </ul>
    </nav>
  </section>
</BaseLayout>

<style>
  /* On the shared left rail like every other page (STEP-0039). This was the
     last surface still centring itself in a narrower column. */
  .code {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--faint);
    line-height: 1;
  }
  .notfound-title {
    margin: var(--space-4) 0 var(--space-6);
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
  }
  .lede {
    margin: 0 0 var(--space-8);
    color: var(--muted);
    font-size: var(--text-lg);
    line-height: 1.6;
  }
  .links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-6);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .links a {
    color: var(--text);
  }
  .links a:hover {
    color: var(--accent-hover);
  }
</style>
