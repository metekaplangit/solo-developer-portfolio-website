---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import Badge from '../../components/Badge.astro';
import DownloadButton from '../../components/DownloadButton.astro';
import FactsLine from '../../components/FactsLine.astro';
import { sortProducts, getFeatured, statusLabel } from '../../lib/products';
import { withBase } from '../../lib/url';
import { resolveScreenshot } from '../../lib/screenshots';
import { breadcrumbSchema, itemListSchema } from '../../lib/schema';

const entries = await getCollection('products');
const products = sortProducts(entries.map((e) => e.data));

// The lead product gets a full-width row; everything else falls to the grid.
const featured = getFeatured(products);
const lead = featured[0] ?? products[0];
const rest = products.filter((p) => p.slug !== lead?.slug);

const leadShot = lead?.screenshots?.[lead.screenshots.length - 1] ?? lead?.screenshots?.[0];
const leadImg = leadShot ? resolveScreenshot(leadShot.path) : undefined;

const schema = [
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Apps & Games', path: '/apps/' },
  ]),
  itemListSchema(products),
];
---

<BaseLayout
  title="Apps & Games"
  description="Every app and game — released, in beta, and planned — each with privacy and support links."
  schema={schema}
>
  <section class="band band-lead catalog-hero" aria-labelledby="catalog-h">
    <h1 id="catalog-h" class="catalog-title">Apps &amp; Games</h1>
    <p class="lede measure">
      Everything the studio has shipped. Each product has its own privacy page
      and its own support page — no shared boilerplate.
    </p>
  </section>

  {
    lead && (
      <section class="band band-loose lead-band" aria-labelledby="lead-h">
        <h2 id="lead-h" class="visually-hidden">{lead.name}</h2>
        <article class="panel panel-accent lead-row reveal">
          <div class="lead-body">
            <div class="tags">
              <Badge label={lead.type === 'game' ? 'Game' : 'App'} tone="accent" />
              <Badge label={statusLabel(lead.status)} />
            </div>
            <h3 class="lead-name">
              <a href={withBase(`/apps/${lead.slug}/`)}>{lead.name}</a>
            </h3>
            <p class="lead-summary">{lead.summary}</p>
            <div class="lead-cta">
              <DownloadButton product={lead} />
              <a class="btn btn-secondary" href={withBase(`/apps/${lead.slug}/`)}>
                View {lead.name}
              </a>
            </div>
            <FactsLine product={lead} />
          </div>
          {
            leadImg && (
              <a class="shot-frame" href={withBase(`/apps/${lead.slug}/`)} aria-label={`Open ${lead.name}`}>
                <Image
                  src={leadImg}
                  alt={leadShot.altText}
                  widths={[480, 720, 960]}
                  sizes="(min-width: 60rem) 34rem, calc(100vw - 6rem)"
                  format="webp"
                  quality={78}
                  loading="eager"
                />
              </a>
            )
          }
        </article>
      </section>
    )
  }

  {
    rest.length > 0 && (
      <section class="band band-tight rest-band" aria-labelledby="rest-h">
        <h2 id="rest-h" class="band-title">Everything else</h2>
        <ul class="grid" role="list">
          {rest.map((p) => (
            <li class="reveal">
              <ProductCard product={p} />
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <section class="band band-tight band-tail closing">
    <p>
      More is in progress. Nothing gets announced here until it&rsquo;s ready to
      install — <a href={withBase('/support/')}>get in touch</a> if you want to
      hear when it is.
    </p>
  </section>
</BaseLayout>

<style>
  .catalog-title {
    margin: 0 0 var(--space-6);
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
  }
  .lede {
    margin: 0;
    color: var(--muted);
    font-size: var(--text-lg);
    line-height: 1.6;
  }

  .lead-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(var(--space-6), 3vw, var(--space-10));
    align-items: center;
  }
  .lead-body {
    min-width: 0;
  }
  .tags {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }
  .lead-name {
    margin: 0 0 var(--space-4);
    font-size: var(--text-2xl);
    letter-spacing: -0.025em;
  }
  .lead-name a {
    color: var(--text-strong);
  }
  .lead-name a:hover {
    text-decoration: underline;
    text-decoration-color: var(--accent);
  }
  .lead-summary {
    margin: 0;
    color: var(--muted);
    line-height: 1.6;
    max-width: var(--measure);
  }
  .lead-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }
  @media (min-width: 60rem) {
    .lead-row {
      grid-template-columns: minmax(0, 1fr) 1fr;
    }
  }
  @media (prefers-reduced-motion: no-preference) {
    .shot-frame {
      transition: transform var(--dur) var(--ease);
    }
    .shot-frame:hover {
      transform: translateY(-3px);
    }
  }

  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-5);
    grid-template-columns: repeat(auto-fit, minmax(min(18rem, 100%), 1fr));
  }

  .closing p {
    margin: 0;
    max-width: var(--measure);
    color: var(--faint);
    font-size: var(--text-sm);
  }
  .closing a {
    color: var(--muted);
  }
  .closing a:hover {
    color: var(--text-strong);
  }
</style>
