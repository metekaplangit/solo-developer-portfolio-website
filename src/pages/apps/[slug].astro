---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Badge from '../../components/Badge.astro';
import ProductAvatar from '../../components/ProductAvatar.astro';
import {
  visibleStoreLinks,
  hasStoreLinks,
  storeLabel,
  statusLabel,
  platformLabel,
  relatedProducts,
} from '../../lib/products';
import { canonicalPrivacyUrl } from '../../lib/privacy';
import { formatDate } from '../../lib/format';
import { withBase } from '../../lib/url';
import { softwareApplicationSchema, breadcrumbSchema } from '../../lib/schema';
import { resolveScreenshot, screenshotTitle } from '../../lib/screenshots';
import ScreenshotShowcase from '../../components/ScreenshotShowcase.astro';
import DownloadButton from '../../components/DownloadButton.astro';
import FactsLine from '../../components/FactsLine.astro';
import FitStatement from '../../components/FitStatement.astro';
import MakerNote from '../../components/MakerNote.astro';

export async function getStaticPaths() {
  const entries = await getCollection('products');
  const all = entries.map((e) => e.data);
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry, related: relatedProducts(all, entry.data) },
  }));
}

interface Props {
  entry: CollectionEntry<'products'>;
  related: Array<CollectionEntry<'products'>['data']>;
}
const { entry, related } = Astro.props;
const product = entry.data;
const { Content } = await render(entry);

const stores = visibleStoreLinks(product);

// Resolve content screenshots to build-time-optimized image assets (astro:assets).
const shots = product.screenshots
  .map((s) => ({ img: resolveScreenshot(s.path), alt: s.altText, title: screenshotTitle(s.path) }))
  .filter((s): s is { img: NonNullable<typeof s.img>; alt: string; title: string } =>
    Boolean(s.img),
  );

const seoTitle = product.seo?.title ?? product.name;
const seoDescription = product.seo?.description ?? product.summary;

const schema = [
  softwareApplicationSchema(product, seoDescription),
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Apps & Games', path: '/apps/' },
    { name: product.name, path: `/apps/${product.slug}/` },
  ]),
];
---

<BaseLayout title={seoTitle} description={seoDescription} schema={schema}>
  <nav class="band back" aria-label="Breadcrumb">
    <a href={withBase('/apps/')}>← Apps &amp; Games</a>
  </nav>

  <!-- Header band: identity and the primary action, nothing else. -->
  <section class="band detail-head" aria-labelledby="product-h">
    <div class="head-grid">
      <ProductAvatar icon={product.icon} name={product.name} size={96} />
      <div class="head-body">
        <div class="tags">
          <Badge label={product.type === 'game' ? 'Game' : 'App'} tone="accent" />
          <Badge label={statusLabel(product.status)} />
          {product.platforms.map((p) => <Badge label={platformLabel(p)} tone="muted" />)}
        </div>
        <h1 id="product-h" class="product-name">{product.name}</h1>
        <p class="summary measure-mid">{product.summary}</p>
      </div>
    </div>

    <div class="action-row">
      <DownloadButton product={product} />
      <a class="btn btn-secondary" href={withBase(canonicalPrivacyUrl(product))}>Privacy details</a>
    </div>
    <FactsLine product={product} />
    <p class="trust-line">
      Made by <a href={withBase('/about/')}>Mete Kaplan</a>{' · '}<a href={withBase('/support/')}>direct support</a>, usually replies in 2–3 business days
    </p>
  </section>

  <div class="band band-loose gallery-band">
    <ScreenshotShowcase shots={shots} label={`${product.name} screenshots`} />
  </div>

  <!-- Who it's for, before the feature list. -->
  <section class="band band-tight fit-band">
    <FitStatement product={product} />
  </section>

  {
    product.features.length > 0 && (
      <section class="band band-tight features-band" aria-labelledby="features-h">
        <h2 id="features-h" class="band-title">What it does</h2>
        <ul class="feature-grid" role="list">
          {product.features.map((f) => (
            <li class="feature reveal">{f}</li>
          ))}
        </ul>
      </section>
    )
  }

  <!-- The description prose, capped at a real measure so it stops running the
       full shell width. This is the band that used to feel most cramped.
       Deliberately a plain `div`, not a labelled `section`: a named section is
       a `region` landmark, and MakerNote's `<aside>` (a `complementary`
       landmark) nested inside one trips axe's
       `landmark-complementary-is-top-level`. -->
  <div class="band band-loose prose-band">
    <div class="prose-grid">
      <div class="prose measure-mid">
        <Content />
      </div>
      {/* The maker's voice runs ALONGSIDE the description rather than in front
          of it. This is also the page's one deliberate asymmetric moment: the
          prose keeps its reading measure and the ~400px that used to sit empty
          beside a 1464px-tall block now carries the one piece of content a
          competitor couldn't reproduce. Sticky so it accompanies the read. */}
      {/* A plain div, not an <aside>: MakerNote already renders an <aside>
          (a complementary landmark), and nesting one inside another trips
          axe's landmark-complementary-is-top-level. */}
      <div class="prose-aside">
        <MakerNote product={product} />
      </div>
    </div>
  </div>

  <section class="band band-loose band-tail get-band" aria-labelledby="get-h">
    <div class="panel panel-accent get reveal">
      <div class="get-copy">
        <h2 id="get-h" class="get-title">Get {product.name}</h2>
        <FactsLine product={product} />
      </div>
      {
        hasStoreLinks(product) ? (
          <div class="get-actions">
            {stores.map((link, i) => (
              <a
                class={`btn ${i === 0 ? 'btn-primary' : 'btn-secondary'}`}
                href={link.url}
                rel="noopener"
                target="_blank"
              >
                {storeLabel(link.store)}
                {link.status === 'coming-soon' ? ' (soon)' : ''}
              </a>
            ))}
          </div>
        ) : (
          <p class="unreleased">Not yet available — check back soon.</p>
        )
      }
    </div>

    {/* Each dt/dd wrapped in a div: as bare grid items they became four equal
        273px tracks with labels and values alternating HORIZONTALLY, so a
        label never sat above its own value. The `dd { margin-top }` below
        proves the intent was label-over-value; it could never fire. */}
    <dl class="meta">
      {
        product.releaseDate && (
          <div class="meta-pair">
            <dt>Released</dt>
            <dd>{formatDate(product.releaseDate)}</dd>
          </div>
        )
      }
      {
        product.lastUpdated && (
          <div class="meta-pair">
            <dt>Last updated</dt>
            <dd>{formatDate(product.lastUpdated)}</dd>
          </div>
        )
      }
      <div class="meta-pair">
        <dt>Privacy &amp; support</dt>
        <dd>
          <a href={withBase(canonicalPrivacyUrl(product))}>Privacy policy</a>{' · '}<a href={withBase(product.supportUrl)}>Support</a>
        </dd>
      </div>
    </dl>

    {
      related.length > 0 && (
        <section class="related" aria-labelledby="related-h">
          <h2 id="related-h" class="band-title">More {product.type === 'game' ? 'games' : 'apps'}</h2>
          <ul role="list">
            {related.map((r) => (
              <li>
                <a href={withBase(`/apps/${r.slug}/`)}>{r.name}</a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </section>
</BaseLayout>

<style>
  .back {
    padding-top: var(--space-8);
    font-size: var(--text-sm);
  }
  .back a {
    color: var(--muted);
  }
  .back a:hover {
    color: var(--text-strong);
  }

  /* Header — icon beside identity. No panel: the page's first band should feel
     open, not boxed. The old header put the icon, name, badges, summary, CTA,
     facts and trust line inside one 43rem card, which is what read as cramped. */
  .detail-head {
    margin-top: var(--space-6);
  }
  .head-grid {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: clamp(var(--space-4), 2.5vw, var(--space-8));
    align-items: start;
  }
  /* Below ~34rem the 96px avatar leaves too little for the name: a product
     whose name is a single long token (e.g. "Chronoscope") pushed the DOCUMENT
     87px wide at 320px — verified by substitution, and an absolute ban. Today's
     "Sole Focus" happens to break into two short words and hides it. Stack
     instead of squeezing. */
  @media (max-width: 34rem) {
    .head-grid {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
  }
  .head-body {
    min-width: 0;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }
  .product-name {
    margin: 0 0 var(--space-4);
    /* Clamped, and allowed to break: `--text-3xl` is a flat 2.75rem, so an
       unbreakable long name at 44px overflowed a 149px track. */
    font-size: clamp(2rem, 6vw, 2.75rem);
    overflow-wrap: anywhere;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
  }
  .summary {
    margin: 0;
    color: var(--muted);
    font-size: var(--text-lg);
    line-height: 1.55;
  }
  .action-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-8);
  }
  .trust-line {
    margin: var(--space-2) 0 0;
    color: var(--faint);
    font-size: var(--text-sm);
  }
  .trust-line a {
    color: var(--muted);
    text-underline-offset: 2px;
  }
  .trust-line a:hover {
    color: var(--text-strong);
  }


  /* Feature grid — one claim per cell, three-up on wide screens. Plain cells,
     no check glyph: the list is already a list, and the accent belongs to the
     download button (One Voice). */
  .feature-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(17rem, 100%), 1fr));
    gap: var(--space-4);
  }
  .feature {
    padding: clamp(var(--space-4), 2vw, var(--space-6));
    border-radius: var(--radius);
    background: linear-gradient(180deg, var(--surface), var(--surface-2));
    color: var(--muted);
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  .prose-grid {
    display: grid;
    gap: var(--gutter);
  }
  /* 75rem, not less: the aside only earns a column when it has room to read.
     At 68rem the second track computed to 205px (~25ch) — cramped, not
     composed. At 75rem+ it is >=320px while the prose keeps its full measure. */
  @media (min-width: 75rem) {
    .prose-grid {
      grid-template-columns: minmax(0, var(--measure-mid)) minmax(0, 1fr);
      align-items: start;
    }
    .prose-aside {
      position: sticky;
      top: var(--space-20);
    }
  }
  @media (max-width: 74.999rem) {
    /* Stacked: the note reads first, as an introduction. */
    .prose-grid {
      display: flex;
      flex-direction: column-reverse;
    }
  }

  .prose :global(p) {
    margin-block: var(--space-4);
    color: var(--muted);
    font-size: var(--text-base);
    line-height: 1.7;
  }
  .prose :global(h2) {
    font-size: var(--text-xl);
    letter-spacing: -0.02em;
    margin: var(--space-12) 0 var(--space-4);
  }
  .prose :global(h2:first-child) {
    margin-top: 0;
  }
  .prose :global(strong) {
    color: var(--text-strong);
    font-weight: 600;
  }

  .get {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }
  .get-copy {
    min-width: 0;
  }
  .get-title {
    margin: 0;
    font-size: var(--text-xl);
    letter-spacing: -0.02em;
  }
  .get-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }
  .unreleased {
    margin: 0;
    color: var(--muted);
  }

  .meta {
    margin: var(--space-10) 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(14rem, 100%), 1fr));
    gap: var(--space-5);
    font-size: var(--text-sm);
  }
  .meta-pair {
    min-width: 0;
  }
  .meta dt {
    font-weight: 600;
    color: var(--text);
  }
  .meta dd {
    margin: var(--space-1) 0 0;
    color: var(--muted);
  }

  .related {
    margin-top: var(--space-10);
    border-top: 1px solid var(--border);
    padding-top: var(--space-8);
  }
  .related ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }
</style>
