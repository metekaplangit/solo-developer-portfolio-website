---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Badge from '../../components/Badge.astro';
import ProductAvatar from '../../components/ProductAvatar.astro';
import {
  visibleStoreLinks,
  hasStoreLinks,
  storeLabel,
  statusLabel,
  relatedProducts,
} from '../../lib/products';
import { canonicalPrivacyUrl } from '../../lib/privacy';
import { formatDate } from '../../lib/format';
import { withBase } from '../../lib/url';
import { softwareApplicationSchema, breadcrumbSchema } from '../../lib/schema';

export async function getStaticPaths() {
  const entries = await getCollection('products');
  const all = entries.map((e) => e.data);
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry, related: relatedProducts(all, entry.data) },
  }));
}

interface Props {
  entry: CollectionEntry<'products'>;
  related: Array<CollectionEntry<'products'>['data']>;
}
const { entry, related } = Astro.props;
const product = entry.data;
const { Content } = await render(entry);

const stores = visibleStoreLinks(product);

const seoTitle = product.seo?.title ?? product.name;
const seoDescription = product.seo?.description ?? product.summary;

const schema = [
  softwareApplicationSchema(product, seoDescription),
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Apps & Games', path: '/apps/' },
    { name: product.name, path: `/apps/${product.slug}/` },
  ]),
];
---

<BaseLayout title={seoTitle} description={seoDescription} schema={schema}>
  <p class="back"><a href={withBase('/apps/')}>← All apps &amp; games</a></p>

  <article class="detail">
    <header class="detail-head">
      <ProductAvatar icon={product.icon} name={product.name} size={72} />
      <div>
        <h1>{product.name}</h1>
        <div class="tags">
          <Badge label={product.type === 'game' ? 'Game' : 'App'} tone="accent" />
          <Badge label={statusLabel(product.status)} />
        </div>
        <p class="summary">{product.summary}</p>
      </div>
    </header>

    <ul class="platforms" aria-label="Platforms">
      {product.platforms.map((p) => <li><Badge label={p} tone="muted" /></li>)}
    </ul>

    {
      product.screenshots.length > 0 && (
        <section aria-labelledby="shots-h">
          <h2 id="shots-h" class="visually-hidden">Screenshots</h2>
          <ul class="shots" role="list">
            {product.screenshots.map((shot) => (
              <li>
                <figure class="shot">
                  <div class="shot-frame" aria-hidden="true">
                    Preview
                  </div>
                  <figcaption>{shot.altText}</figcaption>
                </figure>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <div class="prose"><Content /></div>

    {
      product.features.length > 0 && (
        <section class="reveal" aria-labelledby="features-h">
          <h2 id="features-h">Features</h2>
          <ul class="feature-grid" role="list">
            {product.features.map((f) => (
              <li class="feature">
                <svg class="feature-mark" viewBox="0 0 16 16" aria-hidden="true">
                  <path
                    d="M13 4.5 6.5 11 3.2 7.7"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
                <span>{f}</span>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <section class="reveal" aria-labelledby="get-h">
      <h2 id="get-h">Get it</h2>
      {
        hasStoreLinks(product) ? (
          <ul class="store-links" role="list">
            {stores.map((link, i) => (
              <li>
                <a
                  class={`btn ${i === 0 ? 'btn-primary' : 'btn-secondary'}`}
                  href={link.url}
                  rel="noopener"
                  target="_blank"
                >
                  {storeLabel(link.store)}
                  {link.status === 'coming-soon' ? ' (soon)' : ''}
                </a>
              </li>
            ))}
          </ul>
        ) : (
          <p class="unreleased">Not yet available — check back soon.</p>
        )
      }
    </section>

    <dl class="meta">
      {
        product.releaseDate && (
          <>
            <dt>Released</dt>
            <dd>{formatDate(product.releaseDate)}</dd>
          </>
        )
      }
      {
        product.lastUpdated && (
          <>
            <dt>Last updated</dt>
            <dd>{formatDate(product.lastUpdated)}</dd>
          </>
        )
      }
      <dt>Privacy &amp; support</dt>
      <dd>
        <a href={withBase(canonicalPrivacyUrl(product))}>Privacy policy</a>{' · '}<a href={withBase(product.supportUrl)}>Support</a>
      </dd>
    </dl>
  </article>

  {
    related.length > 0 && (
      <section class="related" aria-labelledby="related-h">
        <h2 id="related-h">More {product.type === 'game' ? 'games' : 'apps'}</h2>
        <ul role="list">
          {related.map((r) => (
            <li>
              <a href={withBase(`/apps/${r.slug}/`)}>{r.name}</a>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</BaseLayout>

<style>
  .back {
    max-width: var(--maxw-prose);
    margin: 0;
    padding-top: var(--space-8);
  }
  .detail {
    max-width: var(--maxw-prose);
    padding-block: var(--space-6) var(--space-8);
  }
  .detail-head {
    display: flex;
    gap: var(--space-5);
    align-items: flex-start;
    margin-top: var(--space-4);
    padding: var(--space-6);
    /* Elevated surface + shadow as the single separation cue (no stacked border). */
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, var(--surface), var(--surface-2));
    box-shadow: var(--shadow-sm);
  }
  .detail h1 {
    margin: 0 0 var(--space-2);
  }
  .tags {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }
  .summary {
    margin: 0;
    color: var(--muted);
    font-size: 1.125rem;
  }
  .platforms,
  .store-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: var(--space-6) 0 0;
    padding: 0;
  }
  .shots {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
    gap: var(--space-4);
    list-style: none;
    margin: var(--space-8) 0 0;
    padding: 0;
  }
  .shot {
    margin: 0;
  }
  .shot-frame {
    display: grid;
    place-items: center;
    aspect-ratio: 16 / 10;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--faint);
    font-size: var(--text-sm);
    background: radial-gradient(120% 120% at 50% 0%, var(--surface-2), var(--surface));
  }
  .shot figcaption {
    margin-top: var(--space-2);
    color: var(--muted);
    font-size: 0.8125rem;
  }
  .prose {
    margin-top: var(--space-8);
  }
  .prose :global(p) {
    margin-block: var(--space-3);
  }
  .unreleased {
    color: var(--muted);
  }
  /* Scannable feature grid — a check-marked card per feature. */
  .feature-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
    gap: var(--space-3);
  }
  .feature {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    border-radius: var(--radius);
    background: var(--surface);
    color: var(--text);
    line-height: 1.4;
  }
  .feature-mark {
    flex: none;
    width: 1.15rem;
    height: 1.15rem;
    margin-top: 0.15em;
    color: var(--accent);
  }
  .meta {
    margin-top: var(--space-8);
    border-top: 1px solid var(--border);
    padding-top: var(--space-6);
  }
  .meta dt {
    font-weight: 600;
    margin-top: var(--space-3);
  }
  .meta dd {
    margin: var(--space-1) 0 0;
    color: var(--muted);
  }
  .related {
    max-width: var(--maxw-prose);
    margin-top: var(--space-8);
    border-top: 1px solid var(--border);
    padding-top: var(--space-6);
  }
  .related ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }
</style>
