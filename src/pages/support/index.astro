---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../lib/site';
import { sortProducts } from '../../lib/products';
import { withBase } from '../../lib/url';

const products = sortProducts((await getCollection('products')).map((e) => e.data));
const subject = encodeURIComponent('Support request');

// What to include in a report — kept as data so the band renders like every
// other card grid on the site rather than as a bulleted list.
const include = [
  { title: 'Which product', body: 'The app or game name, and the platform you’re on.' },
  { title: 'Which version', body: 'The version number, if you can find it. Not essential.' },
  { title: 'What happened', body: 'What you did, what happened, and what you expected instead.' },
];
---

<BaseLayout
  title="Support"
  description="How to get support for any app or game — a direct email, no forms."
>
  <section class="band band-lead support-hero" aria-labelledby="support-h">
    <p class="eyebrow">Support</p>
    <h1 id="support-h" class="support-title">A real person answers.</h1>
    <p class="lede measure">
      Need help with an app or game? Email me directly — there&rsquo;s no form,
      no ticket number, and nothing is tracked.
    </p>
  </section>

  <section class="band band-tight contact-band" aria-labelledby="contact-h">
    <div class="panel panel-accent contact reveal">
      <div class="contact-copy">
        <h2 id="contact-h" class="contact-title">{site.supportEmail}</h2>
        <p>I usually reply within 2–3 business days.</p>
      </div>
      <div class="contact-actions">
        <a class="btn btn-primary" href={`mailto:${site.supportEmail}?subject=${subject}`}>
          Email support
        </a>
      </div>
    </div>
  </section>

  <section class="band band-loose include-band" aria-labelledby="include-h">
    <h2 id="include-h" class="band-title">What to include</h2>
    <ul class="cards card-grid" role="list">
      {
        include.map((i) => (
          <li class="card reveal">
            <h3 class="card-title">{i.title}</h3>
            <p>{i.body}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="band band-tight band-tail products-band" aria-labelledby="products-h">
    <h2 id="products-h" class="band-title">Supported products</h2>
    <ul class="products" role="list">
      {
        products.map((p) => (
          <li>
            <a href={withBase(`/apps/${p.slug}/`)}>{p.name}</a>
          </li>
        ))
      }
    </ul>
    <p class="privacy-ref">
      See the <a href={withBase('/privacy/')}>privacy overview</a> for how data
      is handled.
    </p>
  </section>
</BaseLayout>

<style>
  .support-title {
    margin: var(--space-4) 0 var(--space-6);
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
  }
  .lede {
    margin: 0;
    color: var(--muted);
    font-size: var(--text-lg);
    line-height: 1.6;
  }

  .contact {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }
  .contact-copy {
    min-width: 0;
  }
  /* The address is the heading here — it is the one thing the page exists to
     give you. Mono so a long address wraps predictably and reads as data.

     Sized fluidly rather than at a fixed `--text-lg`, because at that size the
     address does not fit its own panel on a phone: measured at 320px the box is
     224px and the string needs ~288px, so `overflow-wrap` broke it between
     `.co` and `m` — an address split mid-domain reads as a typo on the one page
     whose entire job is handing over a working address. The lower bound keeps
     all 24 characters on one line from 320px up; the upper bound is the
     original `--text-lg`, so nothing changes from ~476px on. */
  .contact-title {
    margin: 0 0 var(--space-2);
    font-family: var(--font-mono);
    font-size: clamp(0.95rem, 4.2vw, var(--text-lg));
    font-weight: 600;
    letter-spacing: -0.01em;
    /* Retained as a safety valve for a future longer address, not as the
       mechanism for this one — the clamp above is what keeps it intact. */
    overflow-wrap: anywhere;
  }
  .contact-copy p {
    margin: 0;
    color: var(--muted);
    font-size: var(--text-sm);
  }
  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  /* Track floor only; everything else is the shared `.card` system. */
  .cards {
    grid-template-columns: repeat(auto-fit, minmax(min(17rem, 100%), 1fr));
  }

  .products {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-6);
  }
  .products a {
    color: var(--text);
  }
  .products a:hover {
    color: var(--accent-hover);
  }
  .privacy-ref {
    margin: var(--space-8) 0 0;
    max-width: var(--measure);
    color: var(--faint);
    font-size: var(--text-sm);
  }
  .privacy-ref a {
    color: var(--muted);
  }
  .privacy-ref a:hover {
    color: var(--text-strong);
  }
</style>
