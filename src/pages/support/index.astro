---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { site } from '../../lib/site';
import { sortProducts } from '../../lib/products';
import { withBase } from '../../lib/url';

const products = sortProducts((await getCollection('products')).map((e) => e.data));
const subject = encodeURIComponent('Support request');
---

<BaseLayout
  title="Support"
  description="How to get support for any app or game — a direct email, no forms."
>
  <PageHeader title="Support">
    <p>
      Need help with an app or game? Email me directly — there's no form, and
      nothing is tracked.
    </p>
  </PageHeader>

  <div class="support">
    <a
      class="btn btn-primary email"
      href={`mailto:${site.supportEmail}?subject=${subject}`}
    >
      {site.supportEmail}
    </a>
    <p class="response">
      This inbox is monitored — I usually reply within 2–3 business days.
    </p>

    <div class="cols reveal">
      <section aria-labelledby="include-h">
        <h2 id="include-h">What to include</h2>
        <ul>
          <li>The product name and the platform you're using.</li>
          <li>The app or game version, if you know it.</li>
          <li>What happened, and what you expected instead.</li>
        </ul>
      </section>

      <section aria-labelledby="products-h">
        <h2 id="products-h">Supported products</h2>
        <ul>
          {products.map((p) => <li>{p.name}</li>)}
        </ul>
      </section>
    </div>

    <p class="privacy-ref">
      See the <a href={withBase('/privacy/')}>privacy overview</a> for how data is
      handled.
    </p>
  </div>
</BaseLayout>

<style>
  .support {
    max-width: var(--maxw-prose);
    margin-inline: auto;
  }
  .email {
    font-size: var(--text-lg);
    padding: 0.85rem 1.5rem;
  }
  .response {
    margin: var(--space-3) 0 0;
    color: var(--muted);
    font-size: var(--text-sm);
  }
  .cols {
    display: grid;
    gap: var(--space-8);
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    margin-top: var(--space-12);
  }
  .support h2 {
    font-size: var(--text-lg);
    margin: 0 0 var(--space-3);
  }
  .support ul {
    margin: 0;
    padding-left: var(--space-5);
    color: var(--muted);
    display: grid;
    gap: var(--space-2);
  }
  .privacy-ref {
    margin-top: var(--space-12);
    color: var(--muted);
  }
</style>
