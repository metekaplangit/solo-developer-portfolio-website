---
// Shared page header (title + optional subtitle via default slot).
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<header class="page-header">
  <h1>{title}</h1>
  <slot />
</header>

<style>
  /* Sits on the shared left rail like every other band (STEP-0038). This used
     to centre itself in a narrower `--maxw-prose` column, which put the title
     on Support/Privacy up to 232px inboard of the nav brand at 1440px — a
     second left edge on the same site. The measure now caps the TEXT, not the
     header. */
  .page-header {
    padding-block: var(--band-y-lg) var(--band-y);
  }
  .page-header h1 {
    margin: 0 0 var(--space-4);
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
  }
  .page-header :global(p) {
    margin: 0;
    max-width: var(--measure);
    color: var(--muted);
    font-size: var(--text-lg);
    line-height: 1.6;
  }
</style>
