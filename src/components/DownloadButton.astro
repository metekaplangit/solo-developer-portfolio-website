---
// Prominent, reusable download CTA (STEP-0028). Renders the product's first
// actionable store link as a branded primary button — Apple glyph for App Store
// targets — so every relevant page can surface the download at the top. Renders
// nothing when the product has no available link (unreleased products degrade
// gracefully). Data-driven from the product content file; no per-page URLs.
import type { Product } from '../content/schema';
import { visibleStoreLinks, storeLabel } from '../lib/products';

interface Props {
  product: Product;
  /** 'md' (default) for page headers/heroes, 'sm' for compact cards. */
  size?: 'md' | 'sm';
}
const { product, size = 'md' } = Astro.props;

const link = visibleStoreLinks(product).find((l) => l.status === 'available');
const isApple = link && (link.store === 'mac-app-store' || link.store === 'app-store');
---

{
  link && (
    <a
      class={`btn btn-primary download-btn ${size === 'sm' ? 'download-sm' : ''}`}
      href={link.url}
      rel="noopener"
      target="_blank"
      aria-label={`Download ${product.name} on the ${storeLabel(link.store)}`}
    >
      {isApple && (
        <svg viewBox="0 0 24 24" aria-hidden="true" class="apple-mark" fill="currentColor">
          <path d="M17.05 12.54c-.03-2.72 2.22-4.02 2.32-4.09-1.27-1.85-3.24-2.1-3.93-2.13-1.67-.17-3.26.98-4.1.98-.85 0-2.16-.96-3.55-.93-1.82.03-3.5 1.06-4.44 2.69-1.9 3.29-.49 8.15 1.36 10.82.9 1.31 1.98 2.77 3.39 2.72 1.36-.05 1.88-.88 3.52-.88 1.65 0 2.11.88 3.55.85 1.47-.02 2.4-1.33 3.29-2.64 1.04-1.52 1.47-2.99 1.49-3.06-.03-.02-2.86-1.1-2.9-4.33zM14.35 4.56c.75-.9 1.25-2.16 1.11-3.41-1.08.04-2.38.72-3.15 1.62-.69.8-1.3 2.07-1.13 3.29 1.2.1 2.42-.61 3.17-1.5z" />
        </svg>
      )}
      <span class="download-label">
        {size === 'sm' ? storeLabel(link.store) : `Download on the ${storeLabel(link.store)}`}
      </span>
    </a>
  )
}

<style>
  .download-btn {
    /* Slightly larger than the base .btn — this is the page's main action. */
    padding: 0.8rem 1.5rem;
    font-size: var(--text-base);
  }
  .apple-mark {
    width: 1.15em;
    height: 1.15em;
    flex: none;
    /* Optically center the glyph against the text baseline. */
    margin-top: -0.1em;
  }
  .download-sm {
    padding: 0.45rem 0.95rem;
    font-size: var(--text-sm);
  }
</style>
