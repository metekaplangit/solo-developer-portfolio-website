---
// Product screenshot gallery. Each shot is a complete, self-contained marketing
// scene (headline + background baked in), so we frame one large at a time and let
// arrows move between them instead of stacking — the section stays compact even
// with 20+ shots. Built on a CSS scroll-snap track: native swipe + trackpad work
// with zero JS, and a small progressive-enhancement script wires the arrows,
// keyboard, and counter on top. Motion honours prefers-reduced-motion.
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Shot {
  img: ImageMetadata;
  alt: string;
}
interface Props {
  shots: Shot[];
  label?: string;
}
const { shots, label = 'Screenshots' } = Astro.props;
const many = shots.length > 1;
---

{
  shots.length > 0 && (
    <section class="gallery reveal" aria-roledescription="carousel" aria-label={label}>
      <div class="frame">
        <ul class="track" role="list">
          {shots.map((shot, i) => (
            <li
              class="slide"
              role="group"
              aria-roledescription="slide"
              aria-label={`${i + 1} of ${shots.length}`}
            >
              <Image
                src={shot.img}
                alt={shot.alt}
                widths={[720, 1080, 1440, 1920]}
                sizes="(min-width: 66rem) 64rem, calc(100vw - 3rem)"
                format="webp"
                quality={78}
                loading={i === 0 ? 'eager' : 'lazy'}
                class="shot-img"
                draggable={false}
              />
            </li>
          ))}
        </ul>

        {many && (
          <>
            <button type="button" class="nav prev" aria-label="Previous screenshot" hidden>
              <svg viewBox="0 0 24 24" aria-hidden="true" width="28" height="28">
                <path
                  d="M15 5 8 12l7 7"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </button>
            <button type="button" class="nav next" aria-label="Next screenshot" hidden>
              <svg viewBox="0 0 24 24" aria-hidden="true" width="28" height="28">
                <path
                  d="M9 5l7 7-7 7"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </button>
            <p class="counter" aria-hidden="true">
              <span class="counter-now">1</span> / {shots.length}
            </p>
          </>
        )}
      </div>

      {many && (
        <ul class="dots" role="list" aria-label="Choose screenshot">
          {shots.map((_, i) => (
            <li>
              <button
                type="button"
                class="dot"
                data-index={i}
                aria-label={`Go to screenshot ${i + 1}`}
              />
            </li>
          ))}
        </ul>
      )}
    </section>
  )
}

<style>
  .gallery {
    /* Breaks out wider than the 40rem prose column, centered on the same axis. */
    max-width: 64rem;
    margin-inline: auto;
    padding-block: var(--space-6);
  }
  .frame {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    /* Hairline ring + soft lift so light-backed scenes still read on the dark page. */
    border: 1px solid var(--border);
    box-shadow: var(--shadow-md);
  }

  /* Scroll-snap rail: one slide per viewport, native swipe/trackpad without JS. */
  .track {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    /* Hide the scrollbar — arrows/dots are the affordance. */
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .track::-webkit-scrollbar {
    display: none;
  }
  .slide {
    flex: 0 0 100%;
    scroll-snap-align: center;
    scroll-snap-stop: always;
  }
  .shot-img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 2880 / 1800;
    -webkit-user-select: none;
    user-select: none;
  }

  /* Arrows — circular glass buttons floated over the left/right edges. */
  .nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    display: grid;
    place-items: center;
    width: 3.5rem;
    height: 3.5rem;
    padding: 0;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-pill);
    color: var(--text-strong);
    /* More opaque so the arrow stays legible over any screenshot. */
    background: rgba(22, 23, 27, 0.78);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    box-shadow: var(--shadow-lg);
    cursor: pointer;
    transition:
      background 0.2s var(--ease),
      border-color 0.2s var(--ease),
      opacity 0.2s var(--ease),
      transform 0.2s var(--ease);
  }
  .nav:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--accent-contrast);
  }
  .nav:active {
    transform: translateY(-50%) scale(0.94);
  }
  .nav:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .nav.prev {
    left: var(--space-4);
  }
  .nav.next {
    right: var(--space-4);
  }
  /* At an end the arrow dims and stops taking pointer events, but stays laid out. */
  .nav[disabled] {
    opacity: 0;
    pointer-events: none;
  }

  /* Position counter — bottom-right pill. */
  .counter {
    position: absolute;
    right: var(--space-4);
    bottom: var(--space-4);
    margin: 0;
    padding: 0.2rem 0.6rem;
    font-size: var(--text-xs);
    font-variant-numeric: tabular-nums;
    color: var(--text-strong);
    background: rgba(22, 23, 27, 0.6);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
  }

  /* Dot rail below the frame. */
  .dots {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2);
    list-style: none;
    margin: var(--space-4) 0 0;
    padding: 0;
  }
  .dot {
    display: block;
    width: 11px;
    height: 11px;
    padding: 0;
    border: 0;
    border-radius: var(--radius-pill);
    background: var(--border-strong);
    cursor: pointer;
    transition:
      background 0.2s var(--ease),
      transform 0.2s var(--ease);
  }
  .dot:hover {
    background: var(--muted);
  }
  .dot[aria-current='true'] {
    background: var(--accent);
    transform: scale(1.35);
  }
  .dot:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Touch devices: native swipe leads, but keep the arrows a comfortable tap size. */
  @media (hover: none) {
    .nav {
      width: 3rem;
      height: 3rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .track {
      scroll-behavior: auto;
    }
    .nav,
    .dot {
      transition: none;
    }
  }
</style>

<script>
  // Progressive enhancement: wire arrows, dots, keyboard, and the live counter to
  // the native scroll-snap track. Falls back to plain swipe/scroll if this never runs.
  function initGallery(root: HTMLElement) {
    const track = root.querySelector<HTMLElement>('.track');
    const prev = root.querySelector<HTMLButtonElement>('.nav.prev');
    const next = root.querySelector<HTMLButtonElement>('.nav.next');
    const counter = root.querySelector<HTMLElement>('.counter-now');
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>('.dot'));
    const slides = Array.from(track?.querySelectorAll<HTMLElement>('.slide') ?? []);
    if (!track || slides.length < 2) return;

    let current = 0;

    const scrollToIndex = (i: number) => {
      const clamped = Math.max(0, Math.min(slides.length - 1, i));
      track.scrollTo({ left: slides[clamped].offsetLeft - track.offsetLeft });
    };

    const render = () => {
      if (counter) counter.textContent = String(current + 1);
      if (prev) prev.disabled = current === 0;
      if (next) next.disabled = current === slides.length - 1;
      dots.forEach((d, i) =>
        d.setAttribute('aria-current', i === current ? 'true' : 'false'),
      );
    };

    // Reveal the arrows only once JS is live (they ship hidden so no-JS users
    // aren't shown dead controls).
    prev?.removeAttribute('hidden');
    next?.removeAttribute('hidden');

    prev?.addEventListener('click', () => scrollToIndex(current - 1));
    next?.addEventListener('click', () => scrollToIndex(current + 1));
    dots.forEach((d) =>
      d.addEventListener('click', () => scrollToIndex(Number(d.dataset.index))),
    );

    // Keyboard: left/right move when the gallery (or a control in it) is focused.
    root.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') {
        e.preventDefault();
        scrollToIndex(current - 1);
      } else if (e.key === 'ArrowRight') {
        e.preventDefault();
        scrollToIndex(current + 1);
      }
    });

    // Derive the active slide from scroll position (covers swipe, arrows, dots alike).
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const i = slides.indexOf(entry.target as HTMLElement);
            if (i !== -1 && i !== current) {
              current = i;
              render();
            }
          }
        }
      },
      { root: track, threshold: 0.6 },
    );
    slides.forEach((s) => io.observe(s));

    render();
  }

  document.querySelectorAll<HTMLElement>('.gallery').forEach(initGallery);
</script>
