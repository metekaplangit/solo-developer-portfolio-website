---
import Badge from './Badge.astro';
import type { Product } from '../content/schema';
import {
  visibleStoreLinks,
  hasStoreLinks,
  storeLabel,
  statusLabel,
} from '../lib/products';
import { canonicalPrivacyUrl } from '../lib/privacy';
import { withBase } from '../lib/url';

interface Props {
  product: Product;
}
const { product } = Astro.props;
const monogram = product.name
  .split(/\s+/)
  .map((w) => w[0])
  .join('')
  .slice(0, 2)
  .toUpperCase();
const stores = visibleStoreLinks(product);
---

<article class="card">
  <div class="card-head">
    {
      product.icon ? (
        <img class="app-icon" src={withBase(product.icon.path)} alt="" width="48" height="48" loading="lazy" />
      ) : (
        <span class="monogram" aria-hidden="true">{monogram}</span>
      )
    }
    <div class="card-titles">
      <h3 class="card-name">
        <a href={withBase(`/apps/${product.slug}/`)}>{product.name}</a>
      </h3>
      <div class="card-tags">
        <Badge label={product.type === 'game' ? 'Game' : 'App'} tone="accent" />
        <Badge label={statusLabel(product.status)} />
      </div>
    </div>
  </div>

  <p class="card-summary">{product.summary}</p>

  <ul class="platforms" aria-label="Platforms">
    {product.platforms.map((p) => <li><Badge label={p} tone="muted" /></li>)}
  </ul>

  <div class="card-links">
    {
      hasStoreLinks(product) ? (
        <ul class="store-links">
          {stores.map((link) => (
            <li>
              <a href={link.url} rel="noopener" target="_blank">
                {storeLabel(link.store)}
                {link.status === 'coming-soon' ? ' (soon)' : ''}
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="unreleased">Not yet available</p>
      )
    }
    <a class="privacy-link" href={withBase(canonicalPrivacyUrl(product))}>
      Privacy<span class="visually-hidden"> for {product.name}</span>
    </a>
  </div>
</article>

<style>
  .card {
    position: relative;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, var(--surface) 0%, var(--surface-2) 100%);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    height: 100%;
    box-shadow: var(--shadow-sm);
    transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease),
      border-color var(--dur) var(--ease);
  }
  .card:hover,
  .card:focus-within {
    transform: translateY(-3px);
    border-color: var(--border-strong);
    box-shadow: var(--shadow-md);
  }
  .card-head {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }
  .monogram {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius);
    background: linear-gradient(145deg, var(--accent-hover), var(--accent));
    color: var(--accent-contrast);
    font-weight: 700;
    letter-spacing: 0.01em;
    flex: none;
    box-shadow: 0 6px 16px -6px var(--accent-glow);
  }
  .app-icon {
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius);
    flex: none;
    box-shadow: var(--shadow-sm);
  }
  .card-name {
    margin: 0;
    font-size: var(--text-lg);
    letter-spacing: -0.01em;
  }
  .card-name a {
    color: var(--text);
    text-decoration: none;
  }
  .card-name a:hover {
    text-decoration: underline;
    text-decoration-color: var(--accent);
  }
  .card-tags {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-1);
  }
  .card-summary {
    margin: 0;
    color: var(--muted);
  }
  .platforms,
  .store-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .card-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-top: auto;
    padding-top: var(--space-3);
  }
  .unreleased {
    margin: 0;
    color: var(--muted);
    font-size: 0.875rem;
  }
  .privacy-link {
    font-size: 0.875rem;
  }
</style>
