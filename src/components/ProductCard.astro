---
import Badge from './Badge.astro';
import ProductAvatar from './ProductAvatar.astro';
import DownloadButton from './DownloadButton.astro';
import type { Product } from '../content/schema';
import {
  visibleStoreLinks,
  hasStoreLinks,
  storeLabel,
  statusLabel,
} from '../lib/products';
import { canonicalPrivacyUrl } from '../lib/privacy';
import { withBase } from '../lib/url';

interface Props {
  product: Product;
}
const { product } = Astro.props;
const stores = visibleStoreLinks(product);
---

<article class="card">
  <div class="card-head">
    <ProductAvatar icon={product.icon} name={product.name} size={48} href={`/apps/${product.slug}/`} redundant />
    <div class="card-titles">
      <h3 class="card-name">
        <a href={withBase(`/apps/${product.slug}/`)}>{product.name}</a>
      </h3>
      <div class="card-tags">
        <Badge label={product.type === 'game' ? 'Game' : 'App'} tone="accent" />
        <Badge label={statusLabel(product.status)} />
      </div>
    </div>
  </div>

  <p class="card-summary">{product.summary}</p>

  <ul class="platforms" aria-label="Platforms">
    {product.platforms.map((p) => <li><Badge label={p} tone="muted" /></li>)}
  </ul>

  <div class="card-links">
    {
      hasStoreLinks(product) ? (
        stores.some((l) => l.status === 'available') ? (
          <DownloadButton product={product} size="sm" />
        ) : (
          <ul class="store-links">
            {stores.map((link) => (
              <li>
                <a href={link.url} rel="noopener" target="_blank">
                  {storeLabel(link.store)}
                  {link.status === 'coming-soon' ? ' (soon)' : ''}
                </a>
              </li>
            ))}
          </ul>
        )
      ) : (
        <p class="unreleased">Not yet available</p>
      )
    }
    <a class="privacy-link" href={withBase(canonicalPrivacyUrl(product))}>
      Privacy<span class="visually-hidden"> for {product.name}</span>
    </a>
  </div>
</article>

<style>
  .card {
    position: relative;
    /* One separation cue: a contrasting elevated surface + shadow, not a
       stacked border (Refactoring UI — prefer fewer borders). */
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, var(--surface) 0%, var(--surface-2) 100%);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    height: 100%;
    /* Shadow for lift + a barely-there inset hairline for a crafted edge. */
    box-shadow: var(--shadow-sm), inset 0 0 0 1px rgba(255, 255, 255, 0.04);
    transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
  }
  .card:hover,
  .card:focus-within {
    transform: translateY(-3px);
    /* Edge brightens on hover — feels like the card lifts toward the light. */
    box-shadow: var(--shadow-md), inset 0 0 0 1px rgba(255, 255, 255, 0.1);
  }
  .card-head {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }
  .card-name {
    margin: 0;
    font-size: var(--text-lg);
    letter-spacing: -0.01em;
  }
  .card-name a {
    color: var(--text);
    text-decoration: none;
  }
  .card-name a:hover {
    text-decoration: underline;
    text-decoration-color: var(--accent);
  }
  .card-tags {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-1);
  }
  .card-summary {
    margin: 0;
    color: var(--muted);
  }
  .platforms,
  .store-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .card-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-top: auto;
    padding-top: var(--space-3);
  }
  .unreleased {
    margin: 0;
    color: var(--muted);
    font-size: 0.875rem;
  }
  .privacy-link {
    font-size: 0.875rem;
  }
</style>
