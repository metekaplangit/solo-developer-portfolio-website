---
// Maker's note (STEP-0035, taste-round T5 — user-approved copy). A short
// first-person rationale that opens the product description: why the app
// exists and what it refuses to become. The voice is the maker's own; the
// exact paragraphs were approved before publication. Renders nothing when the
// content declares no note.
import type { Product } from '../content/schema';
import { site } from '../lib/site';

interface Props {
  product: Product;
}
const { product } = Astro.props;
---

{
  product.makerNote.length > 0 && (
    <aside class="maker-note reveal" aria-label="A note from the maker">
      {product.makerNote.map((para, i) => (
        <p class={i === 0 ? 'lead' : undefined}>{para}</p>
      ))}
      <p class="sig">— {site.person}, {site.name}</p>
    </aside>
  )
}

<style>
  /* Set apart by typography and air, NOT by a coloured side-stripe. A
     `border-left` above 1px used as an accent stripe is an absolute ban (and is
     on DESIGN.md's own don't-list); this component shipped one until
     STEP-0038. The note now reads as a quieter, slightly larger voice with a
     hairline rule closing it — one cue, no stripe. */
  .maker-note {
    padding: 0 0 var(--space-6);
    margin-bottom: var(--space-8);
    border-bottom: 1px solid var(--border);
  }
  .maker-note p {
    margin: 0 0 var(--space-3);
    color: var(--muted);
    line-height: 1.6;
  }
  .maker-note p.lead {
    color: var(--text);
    font-size: 1.05rem;
  }
  .sig {
    margin-bottom: 0;
    color: var(--faint);
    font-size: var(--text-sm);
  }
</style>
