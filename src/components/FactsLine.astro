---
// First-glance facts (STEP-0031, review-0002 COMP-01/USER-02/USER-05; wrapping
// polished in STEP-0037). One quiet middot-separated line of the decision facts
// a visitor needs before clicking through to the store: price, system
// requirement, privacy stance. Every fact is derived from structured product
// content that is already verified elsewhere — this component presents truth, it
// never creates it. Renders nothing when a product has no facts yet.
import type { Product } from '../content/schema';

interface Props {
  product: Product;
}
const { product } = Astro.props;

const facts: string[] = [];
if (product.price === '0') facts.push('Free — no in-app purchases, no subscription');
else if (product.price != null) facts.push(`$${product.price} (one-time)`);
if (product.requirements) facts.push(product.requirements);
if (product.privacyFacts) facts.push(product.privacyFacts);
---

{
  facts.length > 0 && (
    <p class="facts-line">
      {facts.map((f) => (
        <span class="fact">{f}</span>
      ))}
    </p>
  )
}

<style>
  .facts-line {
    margin: var(--space-4) 0 0;
    color: var(--muted);
    font-size: var(--text-sm);
    line-height: 1.65;
  }
  /* Each fact stays whole; the line only ever breaks between facts (never
     mid-phrase), and the separator is breakable so no middot leads a new line. */
  .fact {
    white-space: nowrap;
  }
  .fact:not(:last-child)::after {
    content: '·';
    white-space: normal;
    margin-inline: 0.55em;
    color: var(--faint);
  }
  /* Very narrow screens: let a long fact wrap internally rather than overflow. */
  @media (max-width: 26rem) {
    .fact {
      white-space: normal;
    }
  }
</style>
