---
// One product identity lockup — the app icon, or a monogram fallback built from
// the name. Shared by ProductCard, the app detail header, and the privacy header
// so the same product looks identical everywhere (resolves LEDGER-001).
// When `href` is set, the whole avatar becomes a link to the product.
import { withBase } from '../lib/url';

interface Props {
  /** The product's icon; when absent, a monogram is drawn from `name`. */
  icon?: { path: string; altText?: string } | null;
  name: string;
  /** Rendered size in px. >=56 uses the larger radius + shadow (hero contexts). */
  size?: number;
  /** Alt text for the icon image. Defaults to decorative ('') — the name is adjacent. */
  alt?: string;
  /** When set, the avatar becomes a link to this (site-relative) path. */
  href?: string;
}
const { icon = null, name, size = 48, alt, href } = Astro.props;
const monogram = name
  .split(/\s+/)
  .map((w) => w[0])
  .join('')
  .slice(0, 2)
  .toUpperCase();
const large = size >= 56;
const sizeStyle = `--sz:${size}px`;
// Inside a link the image is decorative — the link's aria-label names the target.
const imgAlt = href ? '' : (alt ?? '');
---

{
  href ? (
    <a class="avatar-link" href={withBase(href)} aria-label={`Open ${name}`}>
      {icon ? (
        <img
          class:list={['avatar', large && 'avatar-lg']}
          src={withBase(icon.path)}
          alt={imgAlt}
          width={size}
          height={size}
          style={sizeStyle}
          loading="lazy"
        />
      ) : (
        <span class:list={['avatar', 'monogram', large && 'avatar-lg']} style={sizeStyle} aria-hidden="true">
          {monogram}
        </span>
      )}
    </a>
  ) : icon ? (
    <img
      class:list={['avatar', large && 'avatar-lg']}
      src={withBase(icon.path)}
      alt={imgAlt}
      width={size}
      height={size}
      style={sizeStyle}
      loading="lazy"
    />
  ) : (
    <span class:list={['avatar', 'monogram', large && 'avatar-lg']} style={sizeStyle} aria-hidden="true">
      {monogram}
    </span>
  )
}

<style>
  .avatar {
    width: var(--sz);
    height: var(--sz);
    flex: none;
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    display: block;
  }
  .avatar-lg {
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }
  .monogram {
    display: grid;
    place-items: center;
    background: linear-gradient(145deg, var(--accent-hover), var(--accent));
    color: var(--accent-contrast);
    font-weight: 700;
    letter-spacing: 0.01em;
    font-size: calc(var(--sz) * 0.32);
    box-shadow: 0 6px 16px -6px var(--accent-glow);
  }

  /* Clickable icon — a subtle lift + press signals it opens the product. */
  .avatar-link {
    display: inline-flex;
    flex: none;
    border-radius: var(--radius-lg);
    line-height: 0;
    transition: transform var(--dur) var(--ease), filter var(--dur) var(--ease);
  }
  .avatar-link:hover {
    transform: translateY(-2px);
    filter: brightness(1.06);
  }
  .avatar-link:active {
    transform: translateY(0) scale(0.97);
    transition-duration: 90ms;
  }
</style>
