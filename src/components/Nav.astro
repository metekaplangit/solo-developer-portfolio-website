---
import { nav, site } from '../lib/site';
import { withBase } from '../lib/url';
const { pathname } = Astro.url;
const norm = (s: string): string => s.replace(/\/+$/, '') || '/';
function isCurrent(href: string): boolean {
  const target = norm(withBase(href));
  const here = norm(pathname);
  if (href === '/') return here === target;
  return here === target || here.startsWith(`${target}/`);
}
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={withBase('/')}>
      <img class="brand-mark" src={withBase('/favicon.svg')} alt="" width="28" height="28" />
      <span>{site.brand}</span>
    </a>
    <nav aria-label="Primary">
      <ul class="nav-list">
        {
          nav.map((item) => (
            <li class={item.href === '/' ? 'nav-home' : undefined}>
              <a
                href={withBase(item.href)}
                aria-current={isCurrent(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  /* Translucent "liquid glass" sticky header — Apple depth cue. */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    -webkit-backdrop-filter: saturate(160%) blur(16px);
    backdrop-filter: saturate(160%) blur(16px);
  }
  .header-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding-block: var(--space-4);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-weight: 700;
    font-size: 1.0625rem;
    letter-spacing: -0.01em;
    text-decoration: none;
    color: var(--text-strong);
  }
  .brand-mark {
    width: 28px;
    height: 28px;
    border-radius: 7px;
    display: block;
  }
  .nav-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-list a {
    display: inline-block;
    text-decoration: none;
    color: var(--muted);
    font-size: var(--text-sm);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-pill);
    transition: color var(--dur) var(--ease), background-color var(--dur) var(--ease);
  }
  .nav-list a:hover {
    color: var(--text-strong);
    background: var(--surface-2);
  }
  .nav-list a[aria-current='page'] {
    color: var(--text-strong);
    background: var(--accent-soft);
    font-weight: 600;
  }

  /* Narrow screens. History: review-0001 OPP-01 replaced a two-row wrap
     (~146px of header) with a single horizontally-scrollable row. That fixed
     the height but hid destinations: measured at 390px, the row was 466px wide
     inside a 331px box — "Support" clipped mid-word and **"About" entirely
     off-screen** (401-466px), behind a mask fade that reads as a rendering
     glitch rather than an affordance. On a site whose whole argument is that a
     real person is behind it, About is the page that carries that, and phone
     visitors could not see it existed.

     The fix is to remove an item rather than to scroll or to wrap. The brand
     lockup to the left IS the home link, so a separate "Home" entry is pure
     redundancy — and dropping it on narrow screens buys back exactly the width
     the row was short. The remaining four destinations then fit on ONE visible
     row with no scroll, no mask, and nothing hidden.

     Wrapping to two rows was tried and rejected: with the `pointer: coarse`
     rule below raising links to 44px, two rows cost ~144px of header on a real
     phone — the very height the 2023 scroll fix existed to avoid. One row of
     four keeps the header at ~93px AND keeps every link a 44px target. */
  @media (max-width: 40rem) {
    .header-inner {
      padding-block: var(--space-3);
      row-gap: var(--space-2);
    }
    .site-header nav {
      width: 100%;
    }
    .nav-list {
      flex-wrap: nowrap;
      justify-content: space-between;
      gap: var(--space-1);
      font-size: var(--text-sm);
      /* Safety valve, not the design. Four items fit without scrolling from
         ~360px up (measured: 0px hidden at 390 and 430). Below that they
         genuinely cannot fit, and without this the row pushed the DOCUMENT
         39px wide at 320px — a horizontal page scroll, which is the one thing
         that is never acceptable. Scrolling a nav is a poor outcome; scrolling
         the page sideways is a broken one. No mask here: the fade it used to
         draw read as a rendering glitch rather than an affordance. */
      overflow-x: auto;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }
    .nav-list::-webkit-scrollbar {
      display: none;
    }
    /* Redundant with the brand link at this width. */
    .nav-home {
      display: none;
    }
    .nav-list a {
      white-space: nowrap;
      padding-inline: var(--space-2);
    }
  }

  /* Touch ergonomics (review-0001 OPP-08): comfortable ≥44px hit height on
     coarse pointers without changing the visual pill design on desktop. */
  @media (pointer: coarse) {
    .nav-list a {
      display: inline-flex;
      align-items: center;
      min-height: 2.75rem;
    }
  }
</style>
