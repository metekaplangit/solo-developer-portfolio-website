---
import { nav, site } from '../lib/site';
import { withBase } from '../lib/url';
const { pathname } = Astro.url;
const norm = (s: string): string => s.replace(/\/+$/, '') || '/';
function isCurrent(href: string): boolean {
  const target = norm(withBase(href));
  const here = norm(pathname);
  if (href === '/') return here === target;
  return here === target || here.startsWith(`${target}/`);
}
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={withBase('/')}>
      <img class="brand-mark" src={withBase('/favicon.svg')} alt="" width="28" height="28" />
      <span>{site.brand}</span>
    </a>
    <nav aria-label="Primary">
      <ul class="nav-list">
        {
          nav.map((item) => (
            <li>
              <a
                href={withBase(item.href)}
                aria-current={isCurrent(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  /* Translucent "liquid glass" sticky header — Apple depth cue. */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    -webkit-backdrop-filter: saturate(160%) blur(16px);
    backdrop-filter: saturate(160%) blur(16px);
  }
  .header-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding-block: var(--space-4);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-weight: 700;
    font-size: 1.0625rem;
    letter-spacing: -0.01em;
    text-decoration: none;
    color: var(--text-strong);
  }
  .brand-mark {
    width: 28px;
    height: 28px;
    border-radius: 7px;
    display: block;
  }
  .nav-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-list a {
    display: inline-block;
    text-decoration: none;
    color: var(--muted);
    font-size: var(--text-sm);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-pill);
    transition: color var(--dur) var(--ease), background-color var(--dur) var(--ease);
  }
  .nav-list a:hover {
    color: var(--text-strong);
    background: var(--surface-2);
  }
  .nav-list a[aria-current='page'] {
    color: var(--text-strong);
    background: var(--accent-soft);
    font-weight: 600;
  }

  /* Narrow screens (review-0001 OPP-01): the five links used to wrap into two
     extra rows, pushing the header to ~146px before content. Keep the brand on
     row one and the destinations in a single horizontally scrollable row —
     zero-JS by design (no disclosure menu). A right-edge fade signals overflow;
     trailing padding keeps the last link clear of the fade. */
  @media (max-width: 40rem) {
    .header-inner {
      padding-block: var(--space-3);
      row-gap: var(--space-2);
    }
    .site-header nav {
      width: 100%;
    }
    .nav-list {
      flex-wrap: nowrap;
      overflow-x: auto;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      padding-inline-end: 24px;
      -webkit-mask-image: linear-gradient(90deg, #000 calc(100% - 28px), transparent);
      mask-image: linear-gradient(90deg, #000 calc(100% - 28px), transparent);
    }
    .nav-list::-webkit-scrollbar {
      display: none;
    }
    .nav-list a {
      white-space: nowrap;
    }
  }

  /* Touch ergonomics (review-0001 OPP-08): comfortable ≥44px hit height on
     coarse pointers without changing the visual pill design on desktop. */
  @media (pointer: coarse) {
    .nav-list a {
      display: inline-flex;
      align-items: center;
      min-height: 2.75rem;
    }
  }
</style>
