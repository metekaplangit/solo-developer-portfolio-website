---
import type { PrivacyPolicyEntry, MediaAsset } from '../content/schema';
import { formatDate } from '../lib/format';
import { withBase } from '../lib/url';

interface Props {
  policy: PrivacyPolicyEntry;
  /** The product's app icon, shown beside the title. Omitted for the site-wide policy. */
  icon?: MediaAsset | null;
}
const { policy, icon = null } = Astro.props;

const collectsData = policy.dataCollected.length > 0;
const hasThirdParties = policy.thirdPartyServices.length > 0;

// At-a-glance chips — the gist in one scan. Each: label + tone.
const chips: { label: string; ok: boolean }[] = [
  { label: collectsData ? 'Minimal data collected' : 'No data collected', ok: !collectsData },
  { label: policy.hasAccounts ? 'Account-based' : 'No account needed', ok: !policy.hasAccounts },
  { label: hasThirdParties ? 'Uses named services' : 'No third-party sharing', ok: !hasThirdParties },
];
---

<article class="policy">
  <header class="policy-head">
    {icon && (
      <img
        class="policy-icon"
        src={withBase(icon.path)}
        alt={icon.altText}
        width="72"
        height="72"
      />
    )}
    <div class="policy-head-text">
      <h1>{policy.title}</h1>
      <p class="policy-meta">
        Updated <time datetime={policy.lastUpdated.toISOString()}>{formatDate(policy.lastUpdated)}</time>{' · '}{policy.effectiveScope}
      </p>
    </div>
  </header>

  <ul class="glance" aria-label="At a glance">
    {chips.map((c) => <li class={c.ok ? 'chip chip-ok' : 'chip'}>{c.label}</li>)}
  </ul>

  <div class="policy-lead"><slot /></div>

  <div class="sections">
    <section class="sec">
      <h2>What we collect</h2>
      {
        collectsData ? (
          <ul>{policy.dataCollected.map((d) => <li>{d}</li>)}</ul>
        ) : (
          <p class="sec-plain">Nothing. This product doesn't collect personal data.</p>
        )
      }
    </section>

    {
      collectsData && (
        <section class="sec">
          <h2>How we use it</h2>
          {policy.dataUse.length > 0 ? (
            <ul>{policy.dataUse.map((d) => <li>{d}</li>)}</ul>
          ) : (
            <p class="sec-plain">Only as described above — never for advertising, profiling, or tracking.</p>
          )}
        </section>
      )
    }

    {
      policy.dataNotCollected.length > 0 && (
        <section class="sec">
          <h2>What we never collect</h2>
          <ul>{policy.dataNotCollected.map((d) => <li>{d}</li>)}</ul>
        </section>
      )
    }

    <section class="sec">
      <h2>Third-party sharing</h2>
      {
        hasThirdParties ? (
          <>
            <ul>{policy.thirdPartyServices.map((d) => <li>{d}</li>)}</ul>
            <p class="sec-note">
              Any third party that touches this data must protect it the same way this
              policy describes. It is never shared with third-party AI services.
            </p>
          </>
        ) : (
          <p class="sec-plain">
            None. Your data isn't shared with anyone — including third-party AI services.
          </p>
        )
      }
    </section>

    <section class="sec">
      <h2>Keeping &amp; deleting your data</h2>
      {
        policy.storedLocally.length > 0 && (
          <>
            <p class="sec-label">Stored only on your device:</p>
            <ul>{policy.storedLocally.map((d) => <li>{d}</li>)}</ul>
          </>
        )
      }
      <p class="sec-plain">{policy.retention}</p>
    </section>

    {
      policy.permissions.length > 0 && (
        <section class="sec">
          <h2>Permissions</h2>
          <ul>{policy.permissions.map((d) => <li>{d}</li>)}</ul>
        </section>
      )
    }

    {
      policy.hasAccounts && (
        <section class="sec">
          <h2>Your account</h2>
          <p class="sec-plain">
            Delete your account and its data from within the app, or email{' '}
            <a href={`mailto:${policy.contact}`}>{policy.contact}</a>.
          </p>
        </section>
      )
    }

    <section class="sec">
      <h2>Contact &amp; requests</h2>
      <p class="sec-plain">
        Questions, consent changes, or deletion requests —
        <a href={`mailto:${policy.contact}`}>{policy.contact}</a>.
      </p>
    </section>
  </div>

  <p class="policy-note">Written in plain language. This is not legal advice.</p>
</article>

<style>
  .policy {
    max-width: var(--maxw-prose);
    padding-block: var(--space-12) var(--space-8);
  }
  .policy-head {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }
  .policy-icon {
    flex: none;
    width: 4.5rem;
    height: 4.5rem;
    /* Full-bleed square artwork — round it into an app tile, like the cards. */
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }
  .policy-head-text {
    min-width: 0;
  }
  .policy-head h1 {
    margin: 0 0 var(--space-2);
  }
  .policy-meta {
    margin: 0;
    color: var(--muted);
    font-size: var(--text-sm);
  }

  /* At a glance */
  .glance {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: var(--space-6) 0 0;
    padding: 0;
  }
  .chip {
    font-size: var(--text-sm);
    font-weight: 600;
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--border);
    background: var(--surface-2);
    color: var(--muted);
  }
  .chip-ok {
    border-color: transparent;
    background: var(--accent-soft);
    color: var(--accent-hover);
  }

  .policy-lead {
    margin-top: var(--space-6);
    font-size: var(--text-lg);
    line-height: 1.55;
    color: var(--text);
  }
  .policy-lead :global(p) {
    margin: 0;
  }

  /* Strictly separated sections */
  .sections {
    margin-top: var(--space-10);
  }
  .sec {
    padding-top: var(--space-6);
    margin-top: var(--space-6);
    border-top: 1px solid var(--border);
  }
  .sec:first-child {
    margin-top: 0;
    padding-top: 0;
    border-top: 0;
  }
  .sec h2 {
    margin: 0 0 var(--space-3);
    font-size: var(--text-lg);
    color: var(--text-strong);
  }
  .sec ul {
    margin: 0;
    padding-left: var(--space-6);
    display: grid;
    gap: var(--space-2);
    color: var(--muted);
  }
  .sec-plain {
    margin: 0;
    color: var(--muted);
  }
  .sec ul + .sec-plain {
    margin-top: var(--space-3);
  }
  .sec-label {
    margin: 0 0 var(--space-2);
    color: var(--text);
    font-weight: 600;
  }
  .sec-note {
    margin: var(--space-3) 0 0;
    font-size: var(--text-sm);
    color: var(--faint);
  }
  .sec a {
    margin-left: 0.25ch;
  }

  .policy-note {
    margin-top: var(--space-10);
    color: var(--faint);
    font-size: var(--text-sm);
  }
</style>
