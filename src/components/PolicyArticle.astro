---
import type { PrivacyPolicyEntry } from '../content/schema';
import { formatDate } from '../lib/format';

interface Props {
  policy: PrivacyPolicyEntry;
}
const { policy } = Astro.props;

// Derived flags for the Apple 5.1.1(i) checklist sections.
const collectsData = policy.dataCollected.length > 0;
const hasThirdParties = policy.thirdPartyServices.length > 0;
---

<article class="policy">
  <header>
    <h1>{policy.title}</h1>
    <p class="policy-meta">
      Last updated <time datetime={policy.lastUpdated.toISOString()}
        >{formatDate(policy.lastUpdated)}</time
      > · Scope: {policy.effectiveScope}
    </p>
  </header>

  <div class="policy-body">
    <slot />
  </div>

  <dl class="policy-facts">
    <dt>What data we collect</dt>
    <dd>
      {
        collectsData ? (
          <ul>{policy.dataCollected.map((d) => <li>{d}</li>)}</ul>
        ) : (
          'None. This product does not collect personal data.'
        )
      }
    </dd>

    <dt>How that data is used</dt>
    <dd>
      {
        policy.dataUse.length > 0 ? (
          <ul>{policy.dataUse.map((d) => <li>{d}</li>)}</ul>
        ) : collectsData ? (
          'Only as described above; not used for advertising, profiling, or tracking.'
        ) : (
          'Not applicable — no data is collected.'
        )
      }
    </dd>

    {
      policy.dataNotCollected.length > 0 && (
        <>
          <dt>Explicitly not collected</dt>
          <dd>
            <ul>{policy.dataNotCollected.map((d) => <li>{d}</li>)}</ul>
          </dd>
        </>
      )
    }

    <dt>Third-party services</dt>
    <dd>
      {
        hasThirdParties ? (
          <>
            <ul>{policy.thirdPartyServices.map((d) => <li>{d}</li>)}</ul>
            <p class="fact-note">
              Any third party with access to this data is required to provide the
              same or equal protection of it as described in this policy. Data is
              not shared with third-party AI services.
            </p>
          </>
        ) : (
          'None. Data is not shared with third parties, including third-party AI services.'
        )
      }
    </dd>

    <dt>Data retention &amp; deletion</dt>
    <dd>{policy.retention}</dd>

    {
      policy.hasAccounts && (
        <>
          <dt>Account deletion</dt>
          <dd>
            You can delete your account and its associated data from within the
            app, or by emailing <a href={`mailto:${policy.contact}`}>{policy.contact}</a>.
          </dd>
        </>
      )
    }

    <dt>Contact &amp; requests</dt>
    <dd>
      Questions, consent changes, or deletion requests:
      <a href={`mailto:${policy.contact}`}>{policy.contact}</a>.
    </dd>
  </dl>

  <p class="policy-note">
    This page is written in plain language and is not legal advice.
  </p>
</article>

<style>
  .policy {
    max-width: 44rem;
    padding-block: var(--space-12) var(--space-8);
  }
  .policy h1 {
    margin: 0 0 var(--space-2);
  }
  .policy-meta {
    margin: 0 0 var(--space-6);
    color: var(--muted);
    font-size: 0.9375rem;
  }
  .policy-body :global(p) {
    margin-block: var(--space-3);
  }
  .policy-facts {
    margin: var(--space-10) 0 0;
    padding: var(--space-6) var(--space-6) var(--space-8);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
  }
  .policy-facts dt {
    font-weight: 600;
    color: var(--text-strong);
    margin-top: var(--space-5);
  }
  .policy-facts dt:first-of-type {
    margin-top: 0;
  }
  .policy-facts dd {
    margin: var(--space-1) 0 0;
    color: var(--muted);
  }
  .policy-facts ul {
    margin: var(--space-1) 0 0;
    padding-left: var(--space-6);
  }
  .policy-facts .fact-note {
    margin: var(--space-2) 0 0;
    font-size: var(--text-sm);
    color: var(--faint);
  }
  .policy-note {
    margin-top: var(--space-8);
    color: var(--muted);
    font-size: 0.875rem;
  }
</style>
