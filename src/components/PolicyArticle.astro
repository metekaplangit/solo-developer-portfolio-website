---
import type { PrivacyPolicyEntry, MediaAsset } from '../content/schema';
import { formatDate } from '../lib/format';
import ProductAvatar from './ProductAvatar.astro';

interface Props {
  policy: PrivacyPolicyEntry;
  /** The product's app icon, shown beside the title. Omitted for the site-wide policy. */
  icon?: MediaAsset | null;
  /** When set, the icon links to the product (e.g. its app detail page). */
  iconHref?: string;
  /** Product name — used for the linked icon's accessible label. */
  iconName?: string;
}
const { policy, icon = null, iconHref, iconName } = Astro.props;

const collectsData = policy.dataCollected.length > 0;
const hasThirdParties = policy.thirdPartyServices.length > 0;
const storesLocally = policy.storedLocally.length > 0;
// Natural subject noun so shared sections read correctly for the site-wide
// policy vs a per-product (app) policy.
const isSite = policy.productId === 'global';
const subject = isSite ? 'This website' : 'This app';

// At-a-glance chips — the gist in one scan. Each: label + tone.
const chips: { label: string; ok: boolean }[] = [
  { label: collectsData ? 'Minimal data collected' : 'No data collected', ok: !collectsData },
  { label: policy.hasAccounts ? 'Account-based' : 'No account needed', ok: !policy.hasAccounts },
  { label: hasThirdParties ? 'Uses named services' : 'No third-party sharing', ok: !hasThirdParties },
];
---

<article class="policy">
  <header class="policy-head">
    {icon && <ProductAvatar icon={icon} name={iconName ?? policy.title} size={72} alt={icon.altText} href={iconHref} />}
    <div class="policy-head-text">
      <h1>{policy.title}</h1>
      <p class="policy-meta">
        Updated <time datetime={policy.lastUpdated.toISOString()}>{formatDate(policy.lastUpdated)}</time>{' · '}{policy.effectiveScope}
      </p>
    </div>
  </header>

  <ul class="glance" aria-label="At a glance">
    {chips.map((c) => <li class={c.ok ? 'chip chip-ok' : 'chip'}>{c.label}</li>)}
  </ul>

  <div class="policy-lead"><slot /></div>

  <div class="sections row-stack">
    <section class="card">
      <h2 class="card-title">What we collect</h2>
      <div class="sec-body">
      {
        collectsData ? (
          <ul>{policy.dataCollected.map((d) => <li>{d}</li>)}</ul>
        ) : (
          <p class="sec-plain">Nothing. This product doesn't collect personal data.</p>
        )
      }
      </div>
    </section>

    {
      collectsData && (
        <section class="card">
          <h2 class="card-title">How we use it</h2>
          <div class="sec-body">
          {policy.dataUse.length > 0 ? (
            <ul>{policy.dataUse.map((d) => <li>{d}</li>)}</ul>
          ) : (
            <p class="sec-plain">Only as described above — never for advertising, profiling, or tracking.</p>
          )}
          </div>
        </section>
      )
    }

    {
      policy.dataNotCollected.length > 0 && (
        <section class="card">
          <h2 class="card-title">What we never collect</h2>
          <div class="sec-body">
          <ul>{policy.dataNotCollected.map((d) => <li>{d}</li>)}</ul>
          </div>
        </section>
      )
    }

    <section class="card">
      <h2 class="card-title">Third-party sharing</h2>
      <div class="sec-body">
      {
        hasThirdParties ? (
          <>
            <ul>{policy.thirdPartyServices.map((d) => <li>{d}</li>)}</ul>
            <p class="sec-note">
              Any third party that touches this data must protect it the same way this
              policy describes. It is never shared with third-party AI services.
            </p>
          </>
        ) : (
          <p class="sec-plain">
            None. Your data isn't shared with anyone — including third-party AI services.
          </p>
        )
      }
      </div>
    </section>

    <section class="card">
      <h2 class="card-title">Keeping &amp; deleting your data</h2>
      <div class="sec-body">
      {
        policy.storedLocally.length > 0 && (
          <>
            <p class="sec-label">Stored only on your device:</p>
            <ul>{policy.storedLocally.map((d) => <li>{d}</li>)}</ul>
          </>
        )
      }
      <p class="sec-plain">{policy.retention}</p>
      </div>
    </section>

    <section class="card">
      <h2 class="card-title">How your data is protected</h2>
      <div class="sec-body">
      <p class="sec-plain">
        {
          storesLocally
            ? "Everything above stays on your device. Because nothing is uploaded to a server, there's no central copy to be breached, leaked, or handed over to anyone."
            : collectsData
              ? 'We protect the limited data we hold with commercially reasonable safeguards, and keep the amount we hold — and the risk — as small as possible. No method of transmission or storage is ever completely secure.'
              : `${subject} keeps nothing about you on any server, so there's nothing to breach, leak, or hand over.`
        }
      </p>
      </div>
    </section>

    {
      policy.permissions.length > 0 && (
        <section class="card">
          <h2 class="card-title">Permissions</h2>
          <div class="sec-body">
          <ul>{policy.permissions.map((d) => <li>{d}</li>)}</ul>
          </div>
        </section>
      )
    }

    {
      policy.hasAccounts && (
        <section class="card">
          <h2 class="card-title">Your account</h2>
          <div class="sec-body">
          <p class="sec-plain">
            Delete your account and its data from within the app, or email{' '}
            <a href={`mailto:${policy.contact}`}>{policy.contact}</a>.
          </p>
          </div>
        </section>
      )
    }

    <section class="card">
      <h2 class="card-title">Children's privacy</h2>
      <div class="sec-body">
      <p class="sec-plain">
        {
          collectsData
            ? `${subject} isn't directed at children under 13, and we don't knowingly collect their personal data. If you believe a child has given us data, contact us and we'll delete it.`
            : `${subject} isn't directed at children, and because it collects no personal data, it holds nothing about children either.`
        }
      </p>
      </div>
    </section>

    <section class="card">
      <h2 class="card-title">Your rights</h2>
      <div class="sec-body">
      <p class="sec-plain">
        {
          collectsData ? (
            <>
              You can ask us to access, correct, delete, or export your personal
              data, or object to how it's used — email{' '}
              <a href={`mailto:${policy.contact}`}>{policy.contact}</a> and we'll respond.
            </>
          ) : (
            <>
              You have the right to access, correct, or delete any personal data we
              hold. Because we hold none, there's nothing to retrieve or erase — but
              if you'd like to confirm that, or make any request, email{' '}
              <a href={`mailto:${policy.contact}`}>{policy.contact}</a>.
            </>
          )
        }
      </p>
      </div>
    </section>

    <section class="card">
      <h2 class="card-title">Contact &amp; requests</h2>
      <div class="sec-body">
      <p class="sec-plain">
        Questions, consent changes, or deletion requests —
        <a href={`mailto:${policy.contact}`}>{policy.contact}</a>.
      </p>
      </div>
    </section>

    <section class="card">
      <h2 class="card-title">Changes to this policy</h2>
      <div class="sec-body">
      <p class="sec-plain">
        We may update this policy as {subject.toLowerCase()} or the law changes. The
        “Updated” date at the top always reflects the current version, and we'll note
        anything significant here.
      </p>
      </div>
    </section>
  </div>

  <p class="policy-note">Written in plain language. This is not legal advice.</p>
</article>

<style>
  /* Brought onto the site's band system (STEP-0039). This used to be one
     narrow hairline-divided column with a different rhythm from every other
     page; it now shares the shell width, the band spacing, and the panel
     treatment the rest of the site uses. Prose still gets a real measure —
     the BAND is wide, the TEXT is capped. */
  .policy {
    padding-block: var(--band-y-lg) var(--band-y);
  }
  .policy-head {
    display: flex;
    align-items: center;
    gap: clamp(var(--space-4), 2.5vw, var(--space-6));
  }
  .policy-head-text {
    min-width: 0;
  }
  /* Fluid rather than a flat `--text-3xl`. Policy titles are the longest
     headings on the site — "MetKap Studio Website Privacy Policy" is 36
     characters — and at a fixed 44px that measured three lines and 139px of
     header on a 390px phone, pushing the at-a-glance chips and the lede down
     the first screen. The cap is the original `--text-3xl`, so desktop is
     unchanged from ~628px up; only phones scale down. */
  .policy-head h1 {
    margin: 0 0 var(--space-3);
    font-size: clamp(1.75rem, 7vw, var(--text-3xl));
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
  }
  .policy-meta {
    margin: 0;
    font-family: var(--font-mono);
    color: var(--faint);
    font-size: var(--text-xs);
  }

  /* At a glance */
  .glance {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: var(--space-8) 0 0;
    padding: 0;
  }
  /* Single cue per chip: a fill, never a fill AND a border. */
  .chip {
    font-size: var(--text-sm);
    font-weight: 600;
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius-pill);
    background: var(--surface-2);
    color: var(--muted);
  }
  .chip-ok {
    background: var(--accent-soft);
    color: var(--accent-hover);
  }

  /* `--muted`, matching every other page's lede. It was `--text` (near-white)
     at 20px, which made this one paragraph brighter than the body copy on
     every other page — the "text colour not matching the rest of the pages"
     inconsistency. */
  .policy-lead {
    margin-top: var(--space-8);
    max-width: var(--measure-mid);
    font-size: var(--text-lg);
    line-height: 1.6;
    color: var(--muted);
  }
  .policy-lead :global(p) {
    margin: 0;
  }

  /* One block per line, full width, heading rail on the left (STEP-0042).
     These were a 3-column card grid with `align-items: start`, which produced
     visibly ragged heights (measured 127/199/127 in a single row) and made a
     reference document read as a dashboard. A policy is scanned top-to-bottom,
     not compared side-by-side. Cards, grid and type all come from the shared
     `.card` system now. */
  .sections {
    margin-top: var(--band-y);
  }
  .sec-body {
    min-width: 0;
    display: grid;
    gap: var(--space-3);
  }
  .sec-plain {
    margin: 0;
    color: var(--muted);
    font-size: var(--text-sm);
    line-height: 1.6;
  }
  .sec-label {
    margin: 0;
    color: var(--text);
    font-weight: 600;
    font-size: var(--text-sm);
  }
  .sec-note {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--faint);
    line-height: 1.6;
  }
  .sec-body :global(a),
  .sections a {
    color: var(--accent);
  }

  .policy-note {
    margin-top: var(--band-y);
    max-width: var(--measure);
    color: var(--faint);
    font-size: var(--text-sm);
  }
</style>
