---
import type { PrivacyPolicyEntry } from '../content/schema';
import { formatDate } from '../lib/format';

interface Props {
  policy: PrivacyPolicyEntry;
}
const { policy } = Astro.props;
---

<article class="policy">
  <header>
    <h1>{policy.title}</h1>
    <p class="policy-meta">
      Last updated <time datetime={policy.lastUpdated.toISOString()}
        >{formatDate(policy.lastUpdated)}</time
      > · Scope: {policy.effectiveScope}
    </p>
  </header>

  <div class="policy-body">
    <slot />
  </div>

  <dl class="policy-facts">
    <dt>Data collected</dt>
    <dd>
      {
        policy.dataCollected.length > 0 ? (
          <ul>{policy.dataCollected.map((d) => <li>{d}</li>)}</ul>
        ) : (
          'None.'
        )
      }
    </dd>

    {
      policy.dataNotCollected.length > 0 && (
        <>
          <dt>Explicitly not collected</dt>
          <dd>
            <ul>{policy.dataNotCollected.map((d) => <li>{d}</li>)}</ul>
          </dd>
        </>
      )
    }

    <dt>Third-party services</dt>
    <dd>
      {
        policy.thirdPartyServices.length > 0 ? (
          <ul>{policy.thirdPartyServices.map((d) => <li>{d}</li>)}</ul>
        ) : (
          'None.'
        )
      }
    </dd>

    <dt>Contact</dt>
    <dd><a href={`mailto:${policy.contact}`}>{policy.contact}</a></dd>
  </dl>

  <p class="policy-note">
    This page is written in plain language and is not legal advice.
  </p>
</article>

<style>
  .policy {
    max-width: 44rem;
    padding-block: var(--space-12) var(--space-8);
  }
  .policy h1 {
    margin: 0 0 var(--space-2);
  }
  .policy-meta {
    margin: 0 0 var(--space-6);
    color: var(--color-muted);
    font-size: 0.9375rem;
  }
  .policy-body :global(p) {
    margin-block: var(--space-3);
  }
  .policy-facts {
    margin: var(--space-8) 0 0;
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-6);
  }
  .policy-facts dt {
    font-weight: 600;
    margin-top: var(--space-4);
  }
  .policy-facts dd {
    margin: var(--space-1) 0 0;
    color: var(--color-muted);
  }
  .policy-facts ul {
    margin: var(--space-1) 0 0;
    padding-left: var(--space-6);
  }
  .policy-note {
    margin-top: var(--space-8);
    color: var(--color-muted);
    font-size: 0.875rem;
  }
</style>
